---
import FixedTabs from "@components/navigation/fixed-tabs/FixedTabs.astro";
import Footer from "@components/navigation/footer/Footer.astro";
import MainNavigation from "@components/navigation/main-nav/MainNav.astro";
import Components from "@components/utils/renderBlock.astro";
import fixedTabsData from "@data/fixedTabs.json";
import footerData from "@data/footer.json";
import mainNavData from "@data/mainNav.json";
import siteInfoData from "@data/siteInfo.json";
import Layout from "@layouts/BaseLayout.astro";

type Props = {
  frontmatter?: {
    title: string;
    description?: string;
    keywords?: string[];
    image?: string;
    canonical?: string;
    landingStyle?: "new-patient-emergency-combo" | "emergency";
    landingPageSections?: any[];
  };
  title?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  canonical?: string;
  mainNav?: Record<string, any>;
  footer?: Record<string, any>;
  siteInfo?: Record<string, any>;
  fixedTabs?: Record<string, any>;
  fixedTabsComponent?: any;
  layoutStyle?: "new-patient-emergency-combo" | "emergency";
};

const {
  frontmatter,
  title: titleProp,
  description: descriptionProp,
  keywords: keywordsProp,
  image: imageProp,
  canonical: canonicalProp,
  mainNav = mainNavData,
  footer = footerData,
  siteInfo = siteInfoData,
  fixedTabs = fixedTabsData,
  fixedTabsComponent: FixedTabsComponent = FixedTabs,
  layoutStyle = "new-patient-emergency-combo",
} = Astro.props as Props;

const title = frontmatter?.title ?? titleProp ?? "";
const description = frontmatter?.description ?? descriptionProp;
const keywords = frontmatter?.keywords ?? keywordsProp;
const image = frontmatter?.image ?? imageProp;
const canonical = frontmatter?.canonical ?? canonicalProp;
const landingPageSections = frontmatter?.landingPageSections;
const hasPageSections = Array.isArray(landingPageSections) && landingPageSections.length > 0;
const hasSlotContent = Astro.slots.has("default");
const fixedTabItems = Array.isArray(fixedTabs?.tabs) ? fixedTabs.tabs : [];
const hasActiveFixedTabs = fixedTabItems.some((tab: any) => tab?.enabled !== false);
const footerSocials = Array.isArray((footer as any)?.socials) ? (footer as any).socials : [];
const sharedSocials = Array.isArray((siteInfo as any)?.socials)
  ? (siteInfo as any).socials
  : footerSocials;
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  canonical={canonical}
>
  <MainNavigation
    {...mainNav}
    offices={siteInfo?.offices}
    socials={sharedSocials}
  />
  <main data-pagefind-body data-landing-style={layoutStyle}>
    {
      hasPageSections ? (
        <Components contentSections={landingPageSections} propName="landingPageSections" />
      ) : hasSlotContent ? (
        <slot />
      ) : null
    }
  </main>
  <Footer
    {...footer}
    siteName={siteInfo?.siteName}
    offices={siteInfo?.offices}
    socials={sharedSocials}
    data-fixed-tabs-active={hasActiveFixedTabs ? "true" : undefined}
  />
  <FixedTabsComponent {...fixedTabs} />
</Layout>
