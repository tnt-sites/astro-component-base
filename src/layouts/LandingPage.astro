---
import Components from "@components/utils/renderBlock.astro";
import footerData from "@data/footer.json";
import mainNavData from "@data/mainNav.json";
import siteInfoData from "@data/siteInfo.json";
import Layout from "@layouts/BaseLayout.astro";

type LandingComponentBlock = Record<string, any>;

type Props = {
  frontmatter?: {
    title: string;
    description?: string;
    keywords?: string[];
    image?: string;
    canonical?: string;
    landingStyle?: string;
    landingMainNav?: LandingComponentBlock | LandingComponentBlock[];
    landingFooter?: LandingComponentBlock | LandingComponentBlock[];
    landingPageSections?: any[];
  };
  title?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  canonical?: string;
  landingStyle?: string;
  mainNav?: Record<string, any>;
  footer?: Record<string, any>;
  siteInfo?: Record<string, any>;
};

const {
  frontmatter,
  title: titleProp,
  description: descriptionProp,
  keywords: keywordsProp,
  image: imageProp,
  canonical: canonicalProp,
  mainNav = mainNavData,
  footer = footerData,
  siteInfo = siteInfoData,
} = Astro.props as Props;

const title = frontmatter?.title ?? titleProp ?? "";
const description = frontmatter?.description ?? descriptionProp;
const keywords = frontmatter?.keywords ?? keywordsProp;
const image = frontmatter?.image ?? imageProp;
const canonical = frontmatter?.canonical ?? canonicalProp;
const normalizeLandingBlocks = (value: unknown, fallbackComponent: string) => {
  const sourceBlocks = Array.isArray(value)
    ? value
    : value && typeof value === "object"
      ? [value]
      : [];

  if (sourceBlocks.length === 0) {
    return [{ _component: fallbackComponent }];
  }

  return sourceBlocks
    .filter((block): block is LandingComponentBlock => !!block && typeof block === "object")
    .map((block) => ({ _component: fallbackComponent, ...block }));
};

const headerBlocks = normalizeLandingBlocks(
  frontmatter?.landingMainNav ?? mainNav,
  "navigation/landing/landing-header"
);
const footerBlocks = normalizeLandingBlocks(
  frontmatter?.landingFooter ?? footer,
  "navigation/footer"
);
const primaryHeader: LandingComponentBlock = headerBlocks[0] ?? {
  _component: "navigation/landing/landing-header",
};
const primaryFooter: LandingComponentBlock = footerBlocks[0] ?? { _component: "navigation/footer" };
const landingPageSections = frontmatter?.landingPageSections;
const hasPageSections = landingPageSections && landingPageSections.length > 0;
const hasSlotContent = Astro.slots.has("default");
const siteInfoOffices: any[] = siteInfo?.offices || [];

// Merge hours from siteInfo into page-level offices that don't define their own
const enrichOfficesWithHours = (offices: any[], fallback: any[]) => {
  if (!offices.length) return fallback;
  return offices.map((office: any, i: number) => {
    const hasHours = Array.isArray(office?.officeHours) && office.officeHours.length > 0;
    if (hasHours) return office;
    const src = fallback[i] ?? fallback[0];
    if (!src) return office;
    return {
      ...office,
      officeHours: src.officeHours ?? [],
      officeHoursNote: office.officeHoursNote ?? src.officeHoursNote,
    };
  });
};

const resolvedHeaderOffices =
  siteInfo?.offices || primaryHeader?.offices || primaryFooter?.offices || [];
const resolvedFooterOffices =
  primaryFooter?.offices || primaryHeader?.offices || siteInfo?.offices || [];
const resolvedSiteName = primaryFooter?.siteName || primaryFooter?.sitename || siteInfo?.siteName;
const resolvedSocials = primaryFooter?.socials || siteInfo?.socials || [];

const isFixedTabsSection = (section: any) => {
  const componentPath =
    typeof section?._component === "string" ? section._component.trim().toLowerCase() : "";

  return componentPath === "navigation/fixed-tabs" || componentPath.endsWith("/fixed-tabs");
};

const fixedTabsSections = Array.isArray(landingPageSections)
  ? landingPageSections.filter((section: any) => isFixedTabsSection(section))
  : [];

const hasActiveFixedTabs = fixedTabsSections.some((section: any) => {
  const tabs = Array.isArray(section?.tabs) ? section.tabs : [];

  return tabs.some((tab: any) => tab?.enabled !== false);
});

const resolvedHeader = {
  ...primaryHeader,
  offices: enrichOfficesWithHours(primaryHeader?.offices ?? resolvedHeaderOffices, siteInfoOffices),
};

const resolvedFooter = {
  ...primaryFooter,
  sitename: primaryFooter?.sitename ?? primaryFooter?.siteName ?? resolvedSiteName,
  siteName: primaryFooter?.siteName ?? primaryFooter?.sitename ?? resolvedSiteName,
  offices: enrichOfficesWithHours(primaryFooter?.offices ?? resolvedFooterOffices, siteInfoOffices),
  socials: primaryFooter?.socials ?? resolvedSocials,
  "data-fixed-tabs-active": hasActiveFixedTabs ? "true" : undefined,
};
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  canonical={canonical}
>
  <Components contentSections={[resolvedHeader]} propName="landingMainNav" editable={false} />
  <main data-pagefind-body>
    {
      hasPageSections ? (
        <Components contentSections={landingPageSections} propName="landingPageSections" />
      ) : hasSlotContent ? (
        <slot />
      ) : null
    }
  </main>
  <Components contentSections={[resolvedFooter]} propName="landingFooter" editable={false} />
</Layout>
