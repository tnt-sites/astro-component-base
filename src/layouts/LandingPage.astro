---
import LandingFixedTabs from "@components/navigation/landing/LandingFixedTabs.astro";
import LandingFooter from "@components/navigation/landing/LandingFooter.astro";
import LandingHeader from "@components/navigation/landing/LandingHeader.astro";
import LandingComponents from "@components/utils/renderLandingBlock.astro";
import fixedTabsData from "@data/fixedTabs.json";
import footerData from "@data/footer.json";
import mainNavData from "@data/mainNav.json";
import siteInfoData from "@data/siteInfo.json";
import Layout from "@layouts/BaseLayout.astro";
import { normalizeLandingStyle } from "@layouts/landing/landingStyles";

type Props = {
  frontmatter?: {
    title: string;
    description?: string;
    keywords?: string[];
    image?: string;
    canonical?: string;
    landingStyle?: string;
    landingMainNav?: Record<string, any>;
    landingFooter?: Record<string, any>;
    landingFixedTabs?: Record<string, any>;
    landingPageSections?: any[];
  };
  title?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  canonical?: string;
  landingStyle?: string;
  mainNav?: Record<string, any>;
  footer?: Record<string, any>;
  siteInfo?: Record<string, any>;
  fixedTabs?: Record<string, any>;
};

const {
  frontmatter,
  title: titleProp,
  description: descriptionProp,
  keywords: keywordsProp,
  image: imageProp,
  canonical: canonicalProp,
  landingStyle: landingStyleProp,
  mainNav = mainNavData,
  footer = footerData,
  siteInfo = siteInfoData,
  fixedTabs = fixedTabsData,
} = Astro.props as Props;

const title = frontmatter?.title ?? titleProp ?? "";
const description = frontmatter?.description ?? descriptionProp;
const keywords = frontmatter?.keywords ?? keywordsProp;
const image = frontmatter?.image ?? imageProp;
const canonical = frontmatter?.canonical ?? canonicalProp;
const resolvedLandingStyle = normalizeLandingStyle(frontmatter?.landingStyle ?? landingStyleProp);
const resolvedMainNav = frontmatter?.landingMainNav ?? mainNav;
const resolvedFooter = frontmatter?.landingFooter ?? footer;
const resolvedFixedTabs = frontmatter?.landingFixedTabs ?? fixedTabs;
const landingPageSections = frontmatter?.landingPageSections;
const hasPageSections = landingPageSections && landingPageSections.length > 0;
const hasSlotContent = Astro.slots.has("default");
const resolvedFooterSocials = (resolvedFooter as any)?.socials || [];
const fixedTabItems = Array.isArray(resolvedFixedTabs?.tabs) ? resolvedFixedTabs.tabs : [];
const hasActiveFixedTabs = fixedTabItems.some((tab: any) => tab?.enabled !== false);
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  canonical={canonical}
>
  <LandingHeader
    {...resolvedMainNav}
    landingStyle={resolvedLandingStyle}
    offices={siteInfo?.offices}
    socials={siteInfo?.socials || resolvedFooterSocials}
  />
  <main data-pagefind-body>
    {
      hasPageSections ? (
        <LandingComponents
          contentSections={landingPageSections}
          propName="landingPageSections"
          landingStyle={resolvedLandingStyle}
        />
      ) : hasSlotContent ? (
        <slot />
      ) : null
    }
  </main>
  <LandingFooter
    {...resolvedFooter}
    landingStyle={resolvedLandingStyle}
    siteName={siteInfo?.siteName}
    offices={siteInfo?.offices}
    socials={siteInfo?.socials || resolvedFooterSocials}
    data-fixed-tabs-active={hasActiveFixedTabs ? "true" : undefined}
  />
  <LandingFixedTabs {...resolvedFixedTabs} landingStyle={resolvedLandingStyle} />
</Layout>
