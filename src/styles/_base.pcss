@import url("base/_animations.pcss");
@import url("base/_html-elements.pcss");
@import url("base/_forms.pcss");
@import url("base/_tables.pcss");
@import url("base/_typography.pcss");

@layer page-sections {
  main {
    overflow: hidden;
  }

  main ol {
    text-align: left;
  }
  main ul {
    list-style: none;
    padding: 0;
    margin: 10px 0;
    text-align: left;
    overflow: hidden;
    li {
      position: relative;
      display: block;
      margin: 0 0 10px 26px;
      padding-left: 24px;
      line-height: 1.6;
      overflow: hidden;
    }
    li:before {
      content: "\e933";
      color: var(--color-brand-secondary);
      font-family: Fontello;
      position: absolute;
      left: 0;
      top: 3px;
      font-size: 0.6em;
    }
  }
  main nav ul,
  main .fixed-tabs,
  main ul.no-check {
    margin: 0;
    li {
      margin: 0;
      padding-left: 0;
      &::before {
        content: none;
      }
    }
  }

  @media (min-width: 800px) {
    ul.two {
      -webkit-column-count: 2;
      column-count: 2;
    }
  }
  @media (max-width: 750px) {
    main ul li {
      margin-left: 10px;
    }
  }

  .office-hours {
    max-width: 270px;
    width: 100%;
    text-align: left;
    --office-hours-day-width: 120px;
    --office-hours-color: var(--color-text);
    --office-hours-day-color: var(--color-text-strong);
    --office-hours-note-color: var(--color-text-muted);

    /* Alignment modifiers — make the block itself left- or right-anchored
       within its container while keeping day→time reading order intact */
    &.office-hours--left {
      display: table;
      margin-right: auto;
    }

    &.office-hours--right {
      display: table;
      margin-left: auto;
    }

    .office-hours-list {
      margin: 0;
    }

    .office-hours-row + .office-hours-row {
      margin-top: 4px;
    }

    .office-hours-line {
      align-items: baseline;
      display: flex;
      flex-wrap: nowrap;
    }

    .office-hours-day {
      color: var(--office-hours-day-color);
      flex: 0 0 var(--office-hours-day-width);
      font-weight: var(--font-weight-semibold);
      white-space: nowrap;
    }

    .office-hours-time {
      color: var(--office-hours-color);
      white-space: nowrap;
    }

    .office-hours-note {
      color: var(--office-hours-note-color);
      display: block;
      font-size: var(--font-size-xs);
      line-height: var(--line-height-snug);
      padding-left: var(--office-hours-day-width);
    }

    .office-hours-general-notes {
      margin-top: var(--spacing-xs);
    }

    .office-hours-general-note {
      color: var(--office-hours-note-color);
      display: block;
      font-size: var(--font-size-xs);
    }
  }

  @media (max-width: 1024px) {
    .office-hours {
      margin-left: auto;
      margin-right: auto;
    }
  }
}
