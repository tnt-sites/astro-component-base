---
import Icon from "@core-elements/icon/Icon.astro";
// @ts-ignore
import MarkdownIt from "markdown-it";

const {
  text: textValue = "",
  iconName,
  iconPosition = "before",
  hideText = false,
  variant = "primary",
  size = "md",
  width = "md",
  borderRadius = "default",
  borderWidth = "default",
  borderColor = "default",
  textColor = "default",
  uppercase = false,
  link,
  modalTarget,
  element = "a",
  class: className,
  editable = true,
  "data-prop": customDataProp = "text",
  _component,
  ...htmlAttributes
} = Astro.props;

const text = typeof textValue === "string" ? textValue : "";
const normalizedText = text
  .replace(/\r\n?/g, "\n")
  .replace(/\n{2,}/g, "\n")
  .trim()
  .replace(/^<p(?:\s[^>]*)?>/i, "")
  .replace(/<\/p>\s*$/i, "");

const md = MarkdownIt({ html: true });
let markdownText = normalizedText ? md.renderInline(normalizedText) : "";
markdownText = markdownText.replace(/\n/g, "<br />");
const textForAria = markdownText
  .replace(/<[^>]*>/g, " ")
  .replace(/\s+/g, " ")
  .trim();

const resolveSelectValue = (value: any): string | undefined => {
  if (typeof value === "string") return value.trim().toLowerCase();
  if (value && typeof value === "object") {
    const candidate = value.id ?? value.value ?? value.name;
    if (typeof candidate === "string") return candidate.trim().toLowerCase();
  }
  return undefined;
};

const normalizeChoice = (value: any, allowed: string[], fallback: string) => {
  const normalized = resolveSelectValue(value);
  return normalized && allowed.includes(normalized) ? normalized : fallback;
};

const normalizedVariant = normalizeChoice(
  variant,
  ["primary", "secondary", "tertiary", "ghost", "text"],
  "primary"
);
const normalizedSize = normalizeChoice(size, ["sm", "md", "lg"], "md");
const normalizedWidth = normalizeChoice(width, ["none", "xs", "sm", "md", "lg", "xl"], "xs");
const normalizedBorderRadius = normalizeChoice(
  borderRadius,
  ["default", "none", "xs", "sm", "md", "lg", "xl", "2xl", "3xl", "4xl", "full"],
  "default"
);
const normalizedBorderWidth = normalizeChoice(
  borderWidth,
  ["default", "none", "xs", "sm", "md"],
  "default"
);
const normalizedBorderColor = normalizeChoice(
  borderColor,
  ["default", "standard", "subtle", "strong", "brand", "transparent"],
  "default"
);
const normalizedTextColor = normalizeChoice(
  textColor,
  ["default", "text", "text-strong", "text-muted", "brand", "text-on-brand", "text-inverse"],
  "default"
);
const normalizedUppercase =
  typeof uppercase === "string" ? uppercase.trim().toLowerCase() === "true" : !!uppercase;
const normalizedIconPosition = normalizeChoice(iconPosition, ["before", "after"], "before");
const normalizedHideText =
  typeof hideText === "string" ? hideText.trim().toLowerCase() === "true" : !!hideText;

const normalizedModalTarget =
  typeof modalTarget === "string" ? modalTarget.trim().replace(/^#/, "") : "";

const textDataAttributes =
  editable && customDataProp
    ? {
        "data-editable": "text",
        "data-prop": customDataProp,
      }
    : {};

if (normalizedHideText && !htmlAttributes["aria-label"] && textForAria) {
  htmlAttributes["aria-label"] = textForAria;
}

const Tag = (normalizedModalTarget ? "button" : element) as any;

const tagProps = normalizedModalTarget
  ? {
      type: "button",
      "data-modal-target": normalizedModalTarget,
      "aria-haspopup": "dialog",
      "aria-controls": normalizedModalTarget,
    }
  : Tag === "a" && link
    ? { href: link }
    : Tag === "button"
      ? { type: "button" }
      : {};

const hasText = normalizedText.length > 0;
const slotContent = Astro.slots.has("default") ? await Astro.slots.render("default") : null;
const hasSlotContent = (slotContent?.toString().trim().length ?? 0) > 0;
const hasIcon = iconName?.trim().length > 0;

if (!_component && !hasText && !hasSlotContent && !hasIcon) return;
---

<Tag
  class:list={[
    "button",
    `variant-${normalizedVariant}`,
    `size-${normalizedSize}`,
    `width-${normalizedWidth}`,
    `radius-${normalizedBorderRadius}`,
    `border-width-${normalizedBorderWidth}`,
    `border-color-${normalizedBorderColor}`,
    `text-color-${normalizedTextColor}`,
    normalizedUppercase && "text-uppercase",
    normalizedIconPosition === "after" && "icon-after",
    normalizedHideText && "icon-only",
    className,
  ]}
  {...tagProps}
  {...htmlAttributes}
>
  <Icon name={iconName} size="none" />
  {
    !normalizedHideText && (
      <span class="label-text" {...textDataAttributes}>
        {normalizedText && <Fragment set:html={markdownText} />}
      </span>
    )
  }
</Tag>

<style lang="pcss" is:global>
  @layer components {
    .button {
      align-items: center;
      background-color: var(--color-bg-surface);
      border: 1px solid var(--color-border);
      border-radius: 30px;
      color: var(--color-text-strong);
      display: inline-flex;
      flex-shrink: 0;
      font-weight: var(--font-weight-semibold);
      gap: 0.15em;
      justify-content: center;
      min-height: 10px;
      min-width: 0;
      padding-block: var(--spacing-em-sm);
      padding-inline: var(--spacing-em-sm);
      text-align: center;
      text-decoration: none;
      transition-duration: var(--animation-normal);
      transition-property: background-color, color, border-color;
      transition-timing-function: ease-in-out;
      vertical-align: middle;
      line-height: 1.2;

      &:hover {
        background-color: var(--color-bg-muted);
        border-color: var(--color-border-strong);
        color: var(--color-text-strong);
        cursor: pointer;
      }

      .big-text{font-size: 1.8rem; text-transform: uppercase;}

      &:focus {
        box-shadow: 0 0 2px 2px var(--color-focus-ring) inset;
        outline: none;
      }

      &.icon-only {
        padding: var(--spacing-em-xs);
      }

      &.icon-after {
        flex-direction: row-reverse;
      }

      &.width-none {
        min-width: 0;
      }

      &.width-sm {
        min-width: 120px;
      }

      &.width-md {
        min-width: 160px;
      }

      &.width-lg {
        min-width: 200px;
      }

      &.width-xl {
        min-width: 240px;
      }

      .label-text {
        display: inline-block;
        line-height: 1.2;
        margin: 0;
        white-space: pre-line;

        .color,
        .heading-color {
          color: var(--color-brand);
        }

        .heading-font {
          font-family: var(--font-body);
          font-style: normal;
          font-weight: var(--font-weight-semibold);
          letter-spacing: 0.02em;
        }
      }

      &.text-uppercase .label-text {
        text-transform: uppercase;
      }

      &.radius-default {
        border-radius: 30px;
      }

      &.radius-none {
        border-radius: var(--radius-none);
      }

      &.radius-xs {
        border-radius: var(--radius-xs);
      }

      &.radius-sm {
        border-radius: var(--radius-sm);
      }

      &.radius-md {
        border-radius: var(--radius-md);
      }

      &.radius-lg {
        border-radius: var(--radius-lg);
      }

      &.radius-xl {
        border-radius: var(--radius-xl);
      }

      &.radius-2xl {
        border-radius: var(--radius-2xl);
      }

      &.radius-3xl {
        border-radius: var(--radius-3xl);
      }

      &.radius-4xl {
        border-radius: var(--radius-4xl);
      }

      &.radius-full {
        border-radius: var(--radius-full);
      }

      &.border-width-default,
      &.border-width-xs {
        border-width: 1px;
      }

      &.border-width-none {
        border-width: 0;
      }

      &.border-width-sm {
        border-width: 2px;
      }

      &.border-width-md {
        border-width: 3px;
      }

      &.border-color-standard {
        border-color: var(--color-border) !important;

        &:hover,
        &:focus {
          border-color: var(--color-border) !important;
        }
      }

      &.border-color-subtle {
        border-color: var(--color-border-subtle) !important;

        &:hover,
        &:focus {
          border-color: var(--color-border-subtle) !important;
        }
      }

      &.border-color-strong {
        border-color: var(--color-border-strong) !important;

        &:hover,
        &:focus {
          border-color: var(--color-border-strong) !important;
        }
      }

      &.border-color-brand {
        border-color: var(--color-brand) !important;

        &:hover,
        &:focus {
          border-color: var(--color-brand) !important;
        }
      }

      &.border-color-transparent {
        border-color: transparent !important;

        &:hover,
        &:focus {
          border-color: transparent !important;
        }
      }

      &.text-color-text {
        color: var(--color-text) !important;

        &:hover,
        &:focus {
          color: var(--color-text) !important;
        }
      }

      &.text-color-text-strong {
        color: var(--color-text-strong) !important;

        &:hover,
        &:focus {
          color: var(--color-text-strong) !important;
        }
      }

      &.text-color-text-muted {
        color: var(--color-text-muted) !important;

        &:hover,
        &:focus {
          color: var(--color-text-muted) !important;
        }
      }

      &.text-color-brand {
        color: var(--color-brand) !important;

        &:hover,
        &:focus {
          color: var(--color-brand) !important;
        }
      }

      &.text-color-text-on-brand {
        color: var(--color-text-on-brand) !important;

        &:hover,
        &:focus {
          color: var(--color-text-on-brand) !important;
        }
      }

      &.text-color-text-inverse {
        color: var(--color-text-inverse) !important;

        &:hover,
        &:focus {
          color: var(--color-text-inverse) !important;
        }
      }

      &.variant-primary {
        background-color: var(--color-bg-brand);
        border-color: transparent;
        color: var(--color-text-on-brand);

        &:hover,
        &:focus {
          background-color: var(--color-bg-brand-muted);
          border-color: transparent;
          color: var(--color-text-on-brand);
        }
      }

      &.variant-secondary {
        background-color: var(--color-bg-brand-secondary);
        border-color: transparent;
          color: var(--color-text-on-brand);

        &:hover,
        &:focus {

          background-color: var(--color-bg-brand-muted);
          border-color: transparent;
          color: #fff;
        }
      }

      &.variant-tertiary {
        background-color: transparent;
        border-color: var(--color-border-strong);
        color: var(--color-text-strong);

        &:hover,
        &:focus {
          background-color: var(--color-bg-surface);
          border-color: var(--color-border-strong);
          color: var(--color-text-strong);
        }
      }

      &.variant-ghost {
        background-color: transparent;
        border-color: transparent;
        color: var(--color-text-strong);

        &:hover,
        &:focus {
          background-color: var(--color-state-hover);
          border-color: transparent;
          color: var(--color-text-strong);
        }
      }

      &.variant-text {
        background-color: transparent;
        border-color: transparent;
        color: var(--color-brand);
        font-size: var(--font-size-lg);
        font-weight: 600;
        padding: 0;

        &:hover,
        &:focus {
          color: var(--color-brand-muted);
        }
      }

      &.size-sm {
        font-size: var(--font-size-xs);
      }

      &.size-md {
        font-size: var(--font-size-md);
      }

      &.size-lg {
        font-size: var(--font-size-xl);
      }

      &.width-sm {
        min-width: 200px;
      }

      &.size-md {
        min-width: 230px;
      }

      &.size-lg {
        min-width: 300px;
      }
    }

    @media (max-width: 768px) {
      .button {
        min-width: auto;
        display: block;
      }
    }
  }
</style>
