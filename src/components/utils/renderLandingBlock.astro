---
export interface Props {
  contentSections: any[];
  propName?: string;
  editable?: boolean;
  landingStyle?: string;
}

const components: Record<string, Function> = {};
const componentImports = import.meta.glob("../**/*.{jsx,astro}", {
  eager: true,
});

function pascalToKebab(pascal: string): string {
  return pascal
    .replace(/([A-Z])/g, "-$1")
    .toLowerCase()
    .replace(/^-/, "");
}

Object.entries(componentImports).forEach(([path, obj]) => {
  const parts = path.replace("../", "").split(".")[0].split("/");
  const filename = parts[parts.length - 1];

  const kebabFilename = pascalToKebab(filename);

  if (parts.length > 1 && kebabFilename === parts[parts.length - 2]) {
    parts.pop();
    parts[parts.length - 1] = kebabFilename;
  } else {
    parts[parts.length - 1] = kebabFilename;
  }

  const componentName = parts.join("/");

  components[componentName] = (obj as any).default;
});

const LANDING_PREFIX = "landing-page-components/";

const {
  contentSections,
  propName = "contentSections",
  editable = true,
  landingStyle,
} = Astro.props;

const landingStyleKey =
  typeof landingStyle === "string" && landingStyle.trim().length > 0
    ? landingStyle.trim().toLowerCase()
    : "";

const landingStyles = Array.from(
  new Set(
    Object.keys(components)
      .filter((key) => key.startsWith(LANDING_PREFIX))
      .map((key) => key.split("/")[1])
      .filter(Boolean)
  )
);

function collapseRepeatedLeafPath(path: string): string {
  const parts = path.split("/");
  const leaf = parts[parts.length - 1];
  const parent = parts[parts.length - 2];

  if (leaf && parent && leaf === parent) {
    return parts.slice(0, -1).join("/");
  }

  return path;
}

function normalizeComponentKey(rawKey: string): string {
  return rawKey
    .trim()
    .replace(/^\/+/, "")
    .replace(/^src\/components\//, "")
    .replace(/^\.\.\//, "");
}

function getComponentCandidates(componentKey: string, styleKey: string): string[] {
  const normalized = normalizeComponentKey(componentKey);
  const candidates: string[] = [normalized, collapseRepeatedLeafPath(normalized)];

  const suffix = normalized.startsWith(LANDING_PREFIX)
    ? normalized.split("/").slice(2).join("/")
    : normalized;

  if (suffix) {
    if (styleKey) {
      candidates.push(`${LANDING_PREFIX}${styleKey}/${suffix}`);
      candidates.push(collapseRepeatedLeafPath(`${LANDING_PREFIX}${styleKey}/${suffix}`));
    }

    landingStyles.forEach((style) => {
      candidates.push(`${LANDING_PREFIX}${style}/${suffix}`);
      candidates.push(collapseRepeatedLeafPath(`${LANDING_PREFIX}${style}/${suffix}`));
    });
  }

  return Array.from(new Set(candidates.filter(Boolean)));
}

function resolveComponent(componentKey: any, styleKey: string) {
  if (typeof componentKey !== "string" || componentKey.trim().length === 0) {
    return undefined;
  }

  const candidates = getComponentCandidates(componentKey, styleKey);

  return candidates.find((candidate) => typeof components[candidate] === "function");
}
---

{
  !editable ? (
    contentSections?.map((block) => {
      const resolvedKey = resolveComponent(block._component, landingStyleKey);
      const Component = resolvedKey ? components[resolvedKey] : undefined;

      if (!Component && block?._component) {
        console.warn(
          `Landing component not found: ${block._component}. Resolved with style: ${landingStyleKey}.`,
          Object.keys(components)
        );
      }

      return Component ? <Component {...block} editable={false} /> : null;
    })
  ) : (
    <editable-array
      data-editable="array"
      data-component-key="_component"
      data-id-key="_component"
      data-prop={propName}
    >
      {contentSections?.map((block) => {
        const resolvedKey = resolveComponent(block._component, landingStyleKey);
        const Component = resolvedKey ? components[resolvedKey] : undefined;

        if (!Component && block?._component) {
          console.warn(
            `Landing component not found: ${block._component}. Resolved with style: ${landingStyleKey}.`,
            Object.keys(components)
          );
        }

        return Component ? (
          <editable-array-item data-id={block._component} data-component={block._component}>
            <Component {...block} />
          </editable-array-item>
        ) : null;
      })}
    </editable-array>
  )
}
