---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@core-elements/image/Image.astro";

const {
  logoSource,
  logoAlt = "Logo",
  siteName = "",
  sitename = "",
  contactTitle = "Contact Us",
  offices = [],
  featuredServicesTitle = "Featured Services",
  featuredServicesLinks = [],
  formTitle = "Ask A Question",
  formAction = "",
  formSubject = "Landing Footer Form",
  formRedirect = "thanks.html",
  formSubmitLabel = "Submit",
  footerLinksBackgroundColor = "brand",
  footerLinksHoverBackgroundColor = "brand-secondary",
  contactCardBackgroundColor = "",
  servicesCardBackgroundColor = "",
  formCardBackgroundColor = "",
  mapEmbedUrl = "",
  legalLinks = [],
  backgroundImage,
  backgroundGradient = "",
  legalBlurb = "",
  id: elementId,
  class: className,
  ...htmlAttributes
} = Astro.props;

const displaySiteName = siteName || sitename;
const copyYear = new Date().getFullYear();
const {
  source = "",
  alt = "",
  positionVertical = "top",
  positionHorizontal = "center",
} = backgroundImage || {};
const backgroundGradientValue =
  typeof backgroundGradient === "string" ? backgroundGradient.trim() : "";
const formActionValue = typeof formAction === "string" ? formAction.trim() : "";
const formSubjectValue = typeof formSubject === "string" ? formSubject.trim() : "";
const formRedirectValue = typeof formRedirect === "string" ? formRedirect.trim() : "";
const formSubmitLabelValue =
  typeof formSubmitLabel === "string" && formSubmitLabel.trim().length > 0
    ? formSubmitLabel.trim()
    : "Submit";
const contactCardBackgroundColorValue =
  typeof contactCardBackgroundColor === "string" ? contactCardBackgroundColor.trim() : "";
const servicesCardBackgroundColorValue =
  typeof servicesCardBackgroundColor === "string" ? servicesCardBackgroundColor.trim() : "";
const formCardBackgroundColorValue =
  typeof formCardBackgroundColor === "string" ? formCardBackgroundColor.trim() : "";
const embedSrc = typeof mapEmbedUrl === "string" ? mapEmbedUrl.trim() : "";
const LINK_COLOR_CHOICES: Record<string, string> = {
  brand: "var(--color-brand)",
  "brand-secondary": "var(--color-brand-secondary)",
  brandsecondary: "var(--color-brand-secondary)",
  accent: "var(--color-accent)",
  dark: "#2c363c",
  black: "#000000",
  white: "#ffffff",
};

const resolveLinkColorChoice = (value: any, fallback: string) => {
  if (typeof value !== "string") return fallback;

  const normalized = value.trim().toLowerCase();

  if (!normalized) return fallback;

  return LINK_COLOR_CHOICES[normalized] || value.trim();
};

const footerLinksBackgroundColorValue = resolveLinkColorChoice(
  footerLinksBackgroundColor,
  "var(--color-brand)"
);
const footerLinksHoverBackgroundColorValue = resolveLinkColorChoice(
  footerLinksHoverBackgroundColor,
  "var(--color-brand-secondary)"
);
const footerBackgroundStyle = [
  backgroundGradientValue ? `--lp-footer-bg-gradient: ${backgroundGradientValue}` : "",
  `--lp-footer-links-bg: ${footerLinksBackgroundColorValue}`,
  `--lp-footer-links-hover-bg: ${footerLinksHoverBackgroundColorValue}`,
]
  .filter(Boolean)
  .join("; ");
const blurb = typeof legalBlurb === "string" ? legalBlurb.trim() : "";

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};

const normalizedOffices = Array.isArray(offices) ? offices : [];
const normalizedServiceLinks = Array.isArray(featuredServicesLinks) ? featuredServicesLinks : [];
---

<footer
  class:list={["landing-footer", "landing-footer-three-cards", className]}
  id={elementId || undefined}
  style={footerBackgroundStyle || undefined}
  {...htmlAttributes}
>
  <Image
    class:list={["background-image"]}
    source={source}
    alt={alt}
    editable={false}
    data-prop-src="backgroundImage.source"
    data-prop-alt="backgroundImage.alt"
    positionVertical={positionVertical}
    positionHorizontal={positionHorizontal}
    background={true}
  />
  <CustomSection maxContentWidth="2xl" paddingHorizontal="md" paddingVertical="xl">
    <div class="lp-footer-shell">
      <div class="lp-footer-content">
        <section
          class="lp-footer-card lp-footer-card--contact"
          style={contactCardBackgroundColorValue
            ? `--lp-footer-card-bg: ${contactCardBackgroundColorValue}`
            : undefined}
        >
          <h3 class="lp-footer-card-title" set:html={contactTitle} />

          {
            embedSrc && (
              <div class="lp-footer-map-slot" aria-label="Office location map">
                <iframe
                  src={embedSrc}
                  title="Office location map"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  allowfullscreen
                />
                {logoSource && (
                  <a href="/" class="lp-footer-mobile-logo" aria-label="Home">
                    <Image
                      source={logoSource}
                      alt={logoAlt}
                      class="lp-footer-logo"
                      editable={false}
                    />
                  </a>
                )}
              </div>
            )
          }

          {
            !embedSrc && logoSource && (
              <a
                href="/"
                class="lp-footer-mobile-logo lp-footer-mobile-logo--standalone"
                aria-label="Home"
              >
                <Image source={logoSource} alt={logoAlt} class="lp-footer-logo" editable={false} />
              </a>
            )
          }

          {
            normalizedOffices.map((office: any) => (
              <div class="lp-footer-office">
                {office?.name && <span class="lp-footer-office-name">{office.name}</span>}

                {Array.isArray(office?.addresses) &&
                  office.addresses.map((address: any) => {
                    const formattedLines = formatAddressLines(address);

                    return formattedLines.length > 0 ? (
                      <a
                        href={address?.mapUrl || "#"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="phy"
                      >
                        {formattedLines.map((line: string, index: number) => (
                          <>
                            {line}
                            {index < formattedLines.length - 1 && <br />}
                          </>
                        ))}
                      </a>
                    ) : null;
                  })}

                {Array.isArray(office?.phones) &&
                  office.phones.map((phone: any) =>
                    phone?.display ? (
                      <a href={phone?.href || "#"} class="pho">
                        {phone.display}
                      </a>
                    ) : null
                  )}
              </div>
            ))
          }
        </section>

        <section
          class="lp-footer-card lp-footer-card--services"
          style={servicesCardBackgroundColorValue
            ? `--lp-footer-card-bg: ${servicesCardBackgroundColorValue}`
            : undefined}
        >
          <h3 class="lp-footer-card-title">{featuredServicesTitle}</h3>
          <ul class="lp-footer-links">
            {
              normalizedServiceLinks.map((item: any) => (
                <li>
                  <a href={item?.path || "#"}>{item?.name || "Service"}</a>
                </li>
              ))
            }
          </ul>
        </section>

        <section
          class="lp-footer-card lp-footer-card--form"
          style={formCardBackgroundColorValue
            ? `--lp-footer-card-bg: ${formCardBackgroundColorValue}`
            : undefined}
        >
          <h3 class="lp-footer-card-title">{formTitle}</h3>
          <form action={formActionValue || "#"} method="post" class="lp-footer-form">
            <input class="lp-footer-input" name="Name" placeholder="Name" required type="text" />
            <input class="lp-footer-input" name="email" placeholder="Email" required type="email" />
            <input class="lp-footer-input" name="phone" placeholder="Phone Number" type="text" />
            <textarea
              class="lp-footer-input lp-footer-textarea"
              name="Message"
              placeholder="Questions/Comments"></textarea>
            <button class="lp-footer-submit" type="submit">{formSubmitLabelValue}</button>
            {formSubjectValue && <input name="_subject" value={formSubjectValue} type="hidden" />}
            {
              formRedirectValue && (
                <input name="_redirect" value={formRedirectValue} type="hidden" />
              )
            }
          </form>
        </section>
      </div>
    </div>

    <div class="lp-footer-copy">
      <span class="footer-legal-line footer-legal-line--primary">
        Copyright &copy;{copyYear}
        {displaySiteName}
      </span>
      {
        legalLinks.length > 0 && (
          <span class="footer-legal-separator" aria-hidden="true">
            |
          </span>
        )
      }
      {
        legalLinks.length > 0 && (
          <span class="footer-legal-line footer-legal-line--links">
            {legalLinks.map((item: any, index: number) => (
              <>
                <a href={item?.path || "#"}>{item?.name || "Link"}</a>
                {index < legalLinks.length - 1 && <span class="mx-2">|</span>}
              </>
            ))}
          </span>
        )
      }
      <span class="footer-legal-separator" aria-hidden="true">|</span>
      <span class="footer-legal-line footer-legal-line--credit">
        Site designed and maintained by <a href="https://www.tntdental.com" target="_blank"
          >TNT Dental</a
        >
      </span>
      {blurb && <p class="lp-footer-blurb">{blurb}</p>}
    </div>
  </CustomSection>
</footer>

<style lang="pcss" is:global>
  @layer page-sections {
    .landing-footer.landing-footer-three-cards {
      position: relative;
      overflow: hidden;

      background-color: #2c363c;
      background-image:
        var(
          --lp-footer-bg-gradient,
          linear-gradient(180deg, color-mix(in srgb, #2c363c 88%, black) 0%, #2c363c 100%)
        );
      background-position: center;
      background-size: cover;
      color: #fff;
      padding: 20px;
      padding-top: 1.4rem;

      > .background-image {
        z-index: var(--layer-1);
      }

      .lp-footer-shell {
        margin: 0 auto;
        max-width: 1360px;
      }

      .lp-footer-logo {
        margin: 0 !important;
      }

      .lp-footer-content {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        justify-content: center;
      }

      .lp-footer-card {
        background: var(--lp-footer-card-bg, #fff);
        border-radius: 15px;
        box-shadow: 1px 3px 7px 0 rgba(0, 0, 0, 0.35);
        color: #1f2633;
        min-height: 430px;
        padding: 1.25rem;
        text-align: center;
      }

      .lp-footer-card-title {
        color: #101926;
        font-family: var(--font-body, sans-serif);
        font-size: 1.9rem;
        font-weight: 300;
        line-height: 1.1;
        margin: 1rem 0 1.25rem;
        text-transform: none;
      }

      .lp-footer-card--services {
        order: 1;
      }

      .lp-footer-card--contact {
        min-height: 520px;
        order: 2;
        padding: 1.5rem 1rem;
        flex: 0 1 540px;
      }

      .lp-footer-card--contact .lp-footer-card-title {
        font-size: clamp(2.2rem, 4vw, 3.15rem);
      }

      .lp-footer-card--form {
        order: 3;
      }

      .lp-footer-office + .lp-footer-office {
        margin-top: 1rem;
      }

      .lp-footer-office-name {
        display: block;
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 0.6rem;
      }

      .lp-footer-office a,
      .lp-footer-links a,
      .lp-footer-copy a {
        color: inherit;
        text-decoration: none;
      }

      .lp-footer-office a {
        display: block;
        margin-top: 0.55rem;
      }

      .pho {
        color: var(--color-brand) !important;
        font-family: var(--font-body, sans-serif);
        font-size: clamp(1.6rem, 2.6vw, 2.5rem);
        font-weight: 700;
        letter-spacing: 0.28px;
        line-height: 1.1;
      }

      .pho:hover {
        color: var(--color-brand-secondary) !important;
      }

      .phy {
        color: #000 !important;
        font-size: 1.25rem;
        line-height: 1.1;
        margin-top: 1rem;
      }

      .phy:hover {
        color: var(--color-brand-secondary) !important;
      }

      .lp-footer-map-slot {
        border-radius: 10px;
        display: block;
        margin-top: 1.25rem;
        overflow: hidden;
        width: 100%;
      }

      .lp-footer-map-slot iframe {
        border: 0;
        display: block;
        height: 220px;
        width: 100%;
      }

      .lp-footer-mobile-logo {
        display: none;
      }

      .lp-footer-mobile-logo--standalone {
        margin-top: 1.25rem;
      }

      .lp-footer-links {
        list-style: none;
        margin: 1.25rem 0 0.5rem;
        padding: 0;
      }

      .lp-footer-links li {
        background-color: var(--lp-footer-links-bg, var(--color-brand));
        border: 1px solid var(--lp-footer-links-bg, var(--color-brand));
        border-radius: 0;
        list-style: none;
        margin: 0.65rem auto;
        text-align: center;
        transition: background-color var(--animation-normal) ease-in-out;
      }

      .lp-footer-links li a {
        color: #fff;
        display: block;
        font-family: var(--font-body, sans-serif);
        font-size: 1.125rem;
        font-weight: 700;
        letter-spacing: 1.8px;
        padding: 1.1rem 1rem 1rem;
        text-transform: uppercase;
      }

      .lp-footer-links li:hover {
        background-color: var(--lp-footer-links-hover-bg, var(--color-brand-secondary));
        border-color: var(--lp-footer-links-hover-bg, var(--color-brand-secondary));
      }

      .lp-footer-form {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin: 1.15rem 0 0.35rem;
      }

      .lp-footer-input {
        background: #ededed;
        border: 0;
        border-radius: 0;
        color: #000;
        font-size: 1.125rem;
        line-height: 1.4;
        margin: 3px auto;
        outline: 0;
        padding: 0.4rem 0.65rem;
        width: 90%;
      }

      .lp-footer-input::placeholder {
        color: #000;
      }
      .lp-footer-input:focus {
        background-color: #f7f4f4;
        box-shadow: inset 0 3px 0 var(--color-brand);
      }

      .lp-footer-textarea {
        min-height: 90px;
        padding-top: 8px;
        resize: vertical;
      }

      .lp-footer-submit {
        align-self: center;
        background: var(--color-brand);
        border: 0;
        border-radius: 0;
        box-shadow: 3px 3px 15px rgba(0, 0, 0, 0.25);
        color: #fff;
        cursor: pointer;
        font-size: 1.125rem;
        font-weight: 700;
        letter-spacing: 0;
        min-width: auto;
        padding: 0.95rem 0.65rem;
        text-transform: uppercase;
        width: 90%;
      }

      .lp-footer-submit:hover,
      .lp-footer-submit:focus {
        background: #2c363c;
        color: #fff;
      }

      .lp-footer-copy {
        color: #fff;
        font: 400 1.125rem/1.4 var(--font-body, sans-serif);
        line-height: 1.4;
        margin-top: 2rem;
        padding: 0.65rem 0 3.75rem;
        text-align: center;
      }

      .lp-footer-copy a {
        color: var(--color-brand);
      }

      .lp-footer-copy a:hover {
        color: #fff;
      }

      .footer-legal-line--credit a {
        color: #fff;
      }

      .footer-legal-line {
        display: inline;
      }

      .footer-legal-separator {
        display: inline;
        margin: 0 0.5rem;
      }

      .lp-footer-blurb {
        font-size: var(--font-size-xs);
        letter-spacing: 0;
        margin: 0.5rem auto 0;
        max-width: 1000px;
        text-transform: none;
      }

      @media (max-width: 1024px) {

         .lp-footer-content {
            display: block;
        }

        .lp-footer-card--services,
        .lp-footer-card--contact,
        .lp-footer-card--form {
          margin: 20px auto;
        }

        .lp-footer-card--contact {
          min-height: 100%;
        }

      }

      @media (max-width: 768px) {
       

        .lp-footer-card--form {
          grid-column: auto;
        }

        .lp-footer-card-title {
          font-size: 2rem;
        }

        .lp-footer-card--contact .lp-footer-card-title {
          font-size: 2.4rem;
        }

        .lp-footer-map-slot iframe {
          display: none;
        }

        .lp-footer-mobile-logo {
          align-items: center;
          display: inline-flex;
          justify-content: center;
          margin: 0.5rem auto;
        }
      }

      @media (max-width: 1024px) {
        .footer-legal-line {
          display: block;
        }

        .footer-legal-line + .footer-legal-line {
          margin-top: 0.25rem;
        }

        .footer-legal-separator {
          display: none;
        }
      }
    }
  }
</style>
