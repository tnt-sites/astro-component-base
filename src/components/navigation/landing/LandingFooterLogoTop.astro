---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@core-elements/image/Image.astro";

const {
  logoSource,
  logoAlt = "Logo",
  siteName = "",
  contactTitle = "Contact Us",
  offices = [],
  socials = [],
  legalLinks = [],
  pageButtons = [],
  mapEmbedUrl = "",
  backgroundImage,
  backgroundGradient = "",
  legalBlurb = "",
  id: elementId,
  class: className,
  ...htmlAttributes
} = Astro.props;

const displaySiteName = siteName;
const copyYear = new Date().getFullYear();
const embedSrc = typeof mapEmbedUrl === "string" ? mapEmbedUrl.trim() : "";
const {
  source = "",
  alt = "",
  positionVertical = "top",
  positionHorizontal = "center",
} = backgroundImage || {};
const backgroundGradientValue =
  typeof backgroundGradient === "string" ? backgroundGradient.trim() : "";
const footerBackgroundStyle = [
  backgroundGradientValue ? `--landing-footer-bg-gradient: ${backgroundGradientValue}` : "",
]
  .filter(Boolean)
  .join("; ");
const blurb = typeof legalBlurb === "string" ? legalBlurb.trim() : "";

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};

const getHoursSource = (source: any) => {
  if (!source || typeof source !== "object") {
    return [];
  }

  return (
    source?.officeHours ?? source?.["office-hours"] ?? source?.office_hours ?? source?.hours ?? []
  );
};

const formatOfficeHours = (source: any) => {
  const rawHours = getHoursSource(source);
  const rawEntries = Array.isArray(rawHours)
    ? rawHours
    : rawHours && typeof rawHours === "object"
      ? Object.entries(rawHours).map(([day, value]: [string, any]) => {
          if (typeof value === "string") {
            return { day, hours: value };
          }

          if (value && typeof value === "object") {
            return { _day: day, ...value };
          }

          return null;
        })
      : [];

  return rawEntries
    .map((entry: any) => {
      if (typeof entry === "string") {
        const line = entry.trim();

        return line.length > 0 ? { day: "", hours: line, note: "" } : null;
      }

      if (!entry || typeof entry !== "object") {
        return null;
      }

      const day =
        typeof entry?.day === "string"
          ? entry.day.trim()
          : typeof entry?.label === "string"
            ? entry.label.trim()
            : typeof entry?._day === "string"
              ? entry._day.trim()
              : "";
      const hours =
        typeof entry?.hours === "string"
          ? entry.hours.trim()
          : typeof entry?.time === "string"
            ? entry.time.trim()
            : typeof entry?.value === "string"
              ? entry.value.trim()
              : typeof entry?.display === "string"
                ? entry.display.trim()
                : "";
      const note =
        typeof entry?.note === "string"
          ? entry.note.trim()
          : typeof entry?.hoursNote === "string"
            ? entry.hoursNote.trim()
            : typeof entry?.["hours-note"] === "string"
              ? entry["hours-note"].trim()
              : typeof entry?.details === "string"
                ? entry.details.trim()
                : "";

      if (!day && !hours && !note) {
        return null;
      }

      return { day, hours, note };
    })
    .filter(Boolean);
};

const getOfficeHoursGeneralNotes = (office: any) => {
  const notes = [
    office?.officeHoursNote,
    office?.["office-hours-note"],
    ...(Array.isArray(office?.officeHoursNotes) ? office.officeHoursNotes : []),
    ...(Array.isArray(office?.["office-hours-notes"]) ? office["office-hours-notes"] : []),
  ];

  return notes.filter((note) => typeof note === "string" && note.trim().length > 0);
};

const getOfficeHoursEntries = (office: any) => {
  const officeHours = formatOfficeHours(office);

  if (officeHours.length > 0) {
    return officeHours;
  }

  const addresses = Array.isArray(office?.addresses) ? office.addresses : [];

  return addresses.reduce((allHours: any[], address: any) => {
    return [...allHours, ...formatOfficeHours(address)];
  }, []);
};
---

<footer
  class:list={["landing-footer", "landing-footer-logo-top", className]}
  id={elementId || undefined}
  style={footerBackgroundStyle || undefined}
  {...htmlAttributes}
>
  <Image
    class:list={["background-image"]}
    source={source}
    alt={alt}
    editable={false}
    data-prop-src="backgroundImage.source"
    data-prop-alt="backgroundImage.alt"
    positionVertical={positionVertical}
    positionHorizontal={positionHorizontal}
    background={true}
  />
  <CustomSection maxContentWidth="2xl" paddingHorizontal="md" paddingVertical="xl">
    <a href="/" class="landing-footer-logo-link">
      <Image source={logoSource} alt={logoAlt} class="landing-footer-logo" editable={false} />
    </a>

    <hr class="landing-footer-divider" />

    <div class="landing-footer-main">
      <div class="landing-footer-contact fo-info">
        <span class="fo-title">{contactTitle}</span>
        {
          offices.map((office: any) => (
            <div class="landing-footer-office">
              {office?.name && <span class="landing-footer-office-name">{office.name}</span>}

              {Array.isArray(office?.phones) &&
                office.phones.map((phone: any) =>
                  phone?.display ? (
                    <a href={phone?.href || "#"} class="pho">
                      {phone?.label ? `${phone.label}: ` : ""}
                      {phone.display}
                    </a>
                  ) : null
                )}

              {Array.isArray(office?.addresses) &&
                office.addresses.map((address: any) => {
                  const formattedLines = formatAddressLines(address);

                  return formattedLines.length > 0 ? (
                    <a
                      href={address?.mapUrl || "#"}
                      class="phy"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {formattedLines.map((line: string, index: number) => (
                        <>
                          {line}
                          {index < formattedLines.length - 1 && <br />}
                        </>
                      ))}
                    </a>
                  ) : null;
                })}
            </div>
          ))
        }
      </div>

      <div class="fo-hours">
        <span class="fo-title">Office Hours</span>
        {
          offices.map((office: any) => {
            const officeHours = getOfficeHoursEntries(office);
            const generalNotes = getOfficeHoursGeneralNotes(office);

            if (!office?.name && officeHours.length === 0 && generalNotes.length === 0) {
              return null;
            }

            return (
              <div class="landing-footer-office">
                {office?.name && <span class="landing-footer-office-name">{office.name}</span>}

                {officeHours.length > 0 && (
                  <div class="office-hours office-hours--left">
                    <div class="office-hours-list">
                      {officeHours.map((hoursItem: any) => (
                        <div class="office-hours-row">
                          <div class="office-hours-line">
                            {hoursItem.day && <span class="office-hours-day">{hoursItem.day}</span>}
                            <span class="office-hours-time">{hoursItem.hours}</span>
                          </div>
                          {hoursItem.note && (
                            <small class="office-hours-note">{hoursItem.note}</small>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {generalNotes.length > 0 && (
                  <div class="office-hours office-hours--left">
                    <div class="office-hours-general-notes">
                      {generalNotes.map((note: string) => (
                        <small class="office-hours-general-note">{note}</small>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            );
          })
        }
      </div>

      {
        embedSrc && (
          <div class="landing-footer-map-embed" aria-label="Map location">
            <iframe
              src={embedSrc}
              title="Office location map"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
          </div>
        )
      }
    </div>

    <div class="copy uppercase letter-spacing-widest text-center">
      <span class="footer-legal-line footer-legal-line--primary">
        &copy; {copyYear}
        {displaySiteName}
      </span>

      {
        legalLinks.length > 0 && (
          <span class="footer-legal-separator" aria-hidden="true">
            |
          </span>
        )
      }

      {
        legalLinks.length > 0 && (
          <span class="footer-legal-line footer-legal-line--links">
            {legalLinks.map((item: any, index: number) => (
              <>
                <a href={item?.path || "#"}>{item?.name || "Link"}</a>
                {index < legalLinks.length - 1 && <span class="mx-2">|</span>}
              </>
            ))}
          </span>
        )
      }

      <span class="footer-legal-separator" aria-hidden="true">|</span>

      <span class="footer-legal-line footer-legal-line--credit">
        Site designed and maintained by <a href="https://www.tntdental.com" target="blank"
          >TNT Dental</a
        >
      </span>

      {blurb && <p class="copy-blurb text-center">{blurb}</p>}
    </div>
  </CustomSection>
</footer>

<style lang="pcss" is:global>
  @layer page-sections {
    .landing-footer.landing-footer-logo-top {
      position: relative;
      overflow: hidden;
      background-color: var(--color-bg-brand-secondary);
      background-image:
        var(
          --landing-footer-bg-gradient,
          linear-gradient(
            180deg,
            color-mix(in srgb, var(--color-bg-brand-secondary) 88%, black) 0%,
            var(--color-bg-brand-secondary) 100%
          )
        );
      background-position: center;
      background-size: cover;
      border-top: 6px solid var(--color-bg-brand);
      color: #fff;
      container-type: inline-size;

      > .background-image {
        z-index: var(--layer-1);
      }

      .content {
        max-width: 100%;
        padding: var(--spacing-lg) 0 0;
      }

      &[data-fixed-tabs-active="true"] {
        @media (max-width: 1024px) {
          padding-bottom: calc(72px + env(safe-area-inset-bottom));
        }
      }

      .landing-footer-logo-link {
        display: block;
        margin: 0 auto;
        max-width: 1150px;
      }

      .landing-footer-logo {
        margin: 0 !important;
      }

      .landing-footer-divider {
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.5);
        margin: 50px auto 20px;
        max-width: 1150px;
      }

      .landing-footer-main {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xl) var(--spacing-lg);
        justify-content: space-around;
        margin: 0 auto;
        max-width: 1350px;
        padding: 50px 10px;
      }

      .landing-footer-contact,
      footer .fo-hours {
        flex: 0 1 auto;
      }

      footer .fo-hours {
        flex: 0 1 305px;
      }

      .fo-title,
      .landing-footer-office-name,
      .pho,
      .phy,
      .copy,
      .copy a {
        color: #fff;
      }

      .fo-title,
      .landing-footer-office-name {
        display: block;
        font-weight: var(--font-weight-semibold);
      }

      .landing-footer-office + .landing-footer-office {
        margin-top: var(--spacing-md);
      }

      .pho,
      .phy,
      .copy a {
        text-decoration: none;

        &:hover,
        &:focus-visible {
          color: var(--color-link-hover);
        }
      }

      .pho {
        display: block;
        font-size: clamp(2rem, 3vw, 2.5rem);
        font-weight: 500;
        line-height: 0.86;
        margin-top: 10px;
      }

      .phy {
        display: block;
        font-size: var(--font-size-sm);
        font-weight: 300;
        line-height: 1.25;
        margin-top: 20px;
      }

      .office-hours {
        --office-hours-color: #fff;
        --office-hours-day-color: #fff;
        --office-hours-day-width: 140px;
        --office-hours-note-color: rgba(255, 255, 255, 0.8);
        margin-top: 20px;
        max-width: none;

        .office-hours-note,
        .office-hours-general-note {
          letter-spacing: 0;
          text-transform: none;
        }
      }

      .landing-footer-map-embed {
        flex: 0 1 463px;
        width: 100%;

        iframe {
          border: 0;
          border-radius: 15px;
          box-shadow: 3px 3px 6px 0 rgba(0, 0, 0, 0.41);
          min-height: 272px;
          width: 100%;
        }
      }

      .copy {
        font-size: var(--font-size-sm);
        line-height: 1.5;
        padding: 20px 10px;
        text-align: center;

        .footer-legal-line {
          display: inline;
        }

        .footer-legal-separator {
          display: inline;
          margin: 0 0.5rem;
        }
      }

      .copy-blurb {
        color: #fff;
        font-size: var(--font-size-sm);
        letter-spacing: 0;
        line-height: var(--line-height-relaxed);
        margin: 20px auto 0;
        max-width: 1150px;
        text-transform: none;
      }

      @media (max-width: 1024px) {
        .copy {
          .footer-legal-line {
            display: block;
          }

          .footer-legal-line + .footer-legal-line {
            margin-top: 0.25rem;
          }

          .footer-legal-separator {
            display: none;
          }
        }
      }

      @container (max-width: 899px) {
        .landing-footer-main {
          justify-content: center;
          text-align: center;
        }

        .office-hours,
        .office-hours.office-hours--left {
          margin-left: auto;
          margin-right: auto;
        }

        .phy,
        .pho {
          margin-left: auto;
          margin-right: auto;
        }
      }
    }
  }
</style>
