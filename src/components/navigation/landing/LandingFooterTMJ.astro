---
import Icon from "@core-elements/icon/Icon.astro";

const {
  logoSource,
  logoAlt = "Logo",
  siteName = "",
  sitename = "",
  contactTitle = "Office Hours",
  offices = [],
  legalLinks = [],
  backgroundImage = "",
  backgroundGradient = "",
  legalBlurb = "",
  getStartedTitle = "How to Get Started",
  getStartedText = "",
  class: className,
  ...htmlAttributes
} = Astro.props;

const displaySiteName = siteName || sitename;
const copyYear = new Date().getFullYear();
const backgroundImageValue = typeof backgroundImage === "string" ? backgroundImage.trim() : "";
const backgroundGradientValue =
  typeof backgroundGradient === "string" ? backgroundGradient.trim() : "";
const footerBackgroundStyle = [
  backgroundImageValue ? `--lf-tmj-bg-image: url("${backgroundImageValue}")` : "",
  backgroundGradientValue ? `--lf-tmj-bg-gradient: ${backgroundGradientValue}` : "",
]
  .filter(Boolean)
  .join("; ");
const blurb = typeof legalBlurb === "string" ? legalBlurb.trim() : "";

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};

const getHoursSource = (source: any) => {
  if (!source || typeof source !== "object") {
    return [];
  }

  return (
    source?.officeHours ?? source?.["office-hours"] ?? source?.office_hours ?? source?.hours ?? []
  );
};

const formatOfficeHours = (source: any) => {
  const rawHours = getHoursSource(source);
  const rawEntries = Array.isArray(rawHours)
    ? rawHours
    : rawHours && typeof rawHours === "object"
      ? Object.entries(rawHours).map(([day, value]: [string, any]) => {
          if (typeof value === "string") {
            return { day, hours: value, note: "" };
          }

          if (value && typeof value === "object") {
            return {
              day,
              hours:
                typeof value?.hours === "string"
                  ? value.hours
                  : typeof value?.time === "string"
                    ? value.time
                    : typeof value?.display === "string"
                      ? value.display
                      : "",
              note:
                typeof value?.note === "string"
                  ? value.note
                  : typeof value?.hoursNote === "string"
                    ? value.hoursNote
                    : "",
            };
          }

          return null;
        })
      : [];

  return rawEntries
    .map((entry: any) => {
      if (typeof entry === "string") {
        const line = entry.trim();

        return line.length > 0 ? { day: "", hours: line, note: "" } : null;
      }

      if (!entry || typeof entry !== "object") {
        return null;
      }

      const day =
        typeof entry?.day === "string"
          ? entry.day.trim()
          : typeof entry?.label === "string"
            ? entry.label.trim()
            : "";

      const hours =
        typeof entry?.hours === "string"
          ? entry.hours.trim()
          : typeof entry?.time === "string"
            ? entry.time.trim()
            : typeof entry?.display === "string"
              ? entry.display.trim()
              : "";

      const note =
        typeof entry?.note === "string"
          ? entry.note.trim()
          : typeof entry?.hoursNote === "string"
            ? entry.hoursNote.trim()
            : typeof entry?.["hours-note"] === "string"
              ? entry["hours-note"].trim()
              : "";

      if (!day && !hours && !note) {
        return null;
      }

      return { day, hours, note };
    })
    .filter(Boolean);
};

const getOfficeHoursEntries = (office: any) => {
  const direct = formatOfficeHours(office);

  if (direct.length > 0) {
    return direct;
  }

  const addresses = Array.isArray(office?.addresses) ? office.addresses : [];

  return addresses.reduce((allHours: any[], address: any) => {
    return [...allHours, ...formatOfficeHours(address)];
  }, []);
};
---

<footer
  class:list={["landing-footer", "landing-footer-tmj", className]}
  style={footerBackgroundStyle || undefined}
  {...htmlAttributes}
>
  <div class="lf-tmj-body">
    <div class="lf-tmj-container">
      <!-- Office Hours column -->
      <section class="lf-tmj-section lf-tmj-hours-section">
        <h3 class="lf-tmj-section-title" set:html={contactTitle} />
        {
          offices.map((office: any) => {
            const officeHours = getOfficeHoursEntries(office);

            return (
              <div class="landing-footer-office">
                {office?.name && <span class="landing-footer-office-name">{office.name}</span>}

                {Array.isArray(office?.phones) &&
                  office.phones.map((phone: any) =>
                    phone?.display ? (
                      <a href={phone?.href || "#"} class="lf-tmj-phone">
                        <Icon name="phone" size="none" class="lf-tmj-icon" aria-hidden="true" />
                        <span>
                          {phone?.label ? `${phone.label}: ` : ""}
                          {phone.display}
                        </span>
                      </a>
                    ) : null
                  )}

                {Array.isArray(office?.addresses) &&
                  office.addresses.map((address: any) => {
                    const formattedLines = formatAddressLines(address);

                    return formattedLines.length > 0 ? (
                      <a
                        href={address?.mapUrl || "#"}
                        class="lf-tmj-address"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <Icon name="map-pin" size="none" class="lf-tmj-icon" aria-hidden="true" />
                        <span>
                          {formattedLines.map((line: string, index: number) => (
                            <>
                              {line}
                              {index < formattedLines.length - 1 && <br />}
                            </>
                          ))}
                        </span>
                      </a>
                    ) : null;
                  })}

                {officeHours.length > 0 && (
                  <div class="office-hours office-hours--left lf-tmj-office-hours">
                    <div class="office-hours-list">
                      {officeHours.map((hoursItem: any) => (
                        <div class="office-hours-row">
                          <div class="office-hours-line">
                            {hoursItem.day && <span class="office-hours-day">{hoursItem.day}</span>}
                            <span class="office-hours-time">{hoursItem.hours}</span>
                          </div>
                          {hoursItem.note && (
                            <small class="office-hours-note">{hoursItem.note}</small>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            );
          })
        }
      </section>

      <span class="lf-tmj-divider" aria-hidden="true"></span>

      <!-- How to Get Started column -->
      <section class="lf-tmj-section lf-tmj-started-section">
        {getStartedTitle && <h2 class="lf-tmj-started-title">{getStartedTitle}</h2>}
        {
          getStartedText && (
            <p class="lf-tmj-started-text" data-prop="getStartedText">
              {getStartedText}
            </p>
          )
        }
      </section>
    </div>
  </div>

  <div class="lf-tmj-copyright">
    <span>
      Copyright &copy;{copyYear}
      {displaySiteName}
    </span>
    {
      legalLinks.length > 0 && (
        <>
          <em>|</em>
          {legalLinks.map((item: any, index: number) => (
            <>
              <a href={item?.path || "#"}>{item?.name || "Link"}</a>
              {index < legalLinks.length - 1 && <em>|</em>}
            </>
          ))}
        </>
      )
    }
    <em>|</em>
    Site designed and maintained by <a href="https://www.tntdental.com" target="_blank"
      >TNT Dental</a
    >
    {blurb && <p class="lf-tmj-blurb">{blurb}</p>}
  </div>
</footer>

<style lang="pcss" is:global>
  @layer page-sections {
    .landing-footer.landing-footer-tmj {
      background-color: #fff;
      background-image:
        var(--lf-tmj-bg-gradient, none),
        var(--lf-tmj-bg-image, none);
      background-position: center;
      background-size: cover;
      color: var(--color-text, #313131);
      padding: 0 10px;
      position: relative;
      text-align: center;

      .lf-tmj-body {
        background-color: #fff;
      }

      .lf-tmj-container {
        align-items: flex-start;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        margin: auto;
        max-width: 1350px;
        padding: 90px 10px;
      }

      .lf-tmj-divider {
        background-color: #e9e9e9;
        display: inline-block;
        height: 237px;
        margin: auto;
        width: 2px;
      }

      .lf-tmj-section {
        padding: 0 20px;
      }

      /* Office Hours column */
      .lf-tmj-hours-section {
        flex: 0 1 320px;
        text-align: left;
      }

      .lf-tmj-section-title {
        color: var(--color-text, #000);
        font-size: 22px;
        font-weight: 300;
        line-height: 1;
        margin: 0 0 var(--spacing-md, 1rem);
        text-transform: none;

        p {
          margin: 0;
        }
      }

      .landing-footer-office + .landing-footer-office {
        margin-top: var(--spacing-md);
      }

      .lf-tmj-phone,
      .lf-tmj-address {
        align-items: flex-start;
        color: var(--color-text, #313131);
        display: flex;
        gap: 8px;
        margin-bottom: var(--spacing-xs, 0.5rem);
        text-decoration: none;

        &:hover {
          color: var(--color-text-strong, #000);
        }

        .lf-tmj-icon {
          color: var(--color-bg-brand, #1689a5);
          flex-shrink: 0;
          font-size: 18px;
          margin-top: 2px;
        }
      }

      .lf-tmj-office-hours {
        --office-hours-color: var(--color-text, #313131);
        --office-hours-day-color: var(--color-text-strong, #000);
        --office-hours-note-color: var(--color-text-muted, #666);
        --office-hours-day-width: 110px;
        margin-top: var(--spacing-sm, 0.75rem);
        max-width: 350px;
      }

      /* How to Get Started column */
      .lf-tmj-started-section {
        align-self: center;
        flex: 0 1 525px;
        text-align: center;
      }

      .lf-tmj-started-title {
        color: var(--color-text, #000);
        font-size: 45px;
        font-weight: 400;
        line-height: 1.17;
        margin: 0 auto 15px;
        text-align: left;
      }

      .lf-tmj-started-text {
        font-size: 17px;
        line-height: 1.67;
        margin: 25px auto 0;
        max-width: 100%;
        text-align: left;
      }

      /* Copyright bar */
      .lf-tmj-copyright {
        color: #313131;
        font-size: 15px;
        letter-spacing: 0.1em;
        line-height: 1.3;
        padding: 40px 0;
        text-align: center;
        text-transform: uppercase;

        em {
          font-style: normal;
          margin: 0 6px;
        }

        a {
          color: var(--color-bg-brand, #1689a5);
          text-decoration: none;

          &:hover {
            color: #000;
          }
        }
      }

      .lf-tmj-blurb {
        font-size: var(--font-size-xs);
        letter-spacing: 0;
        margin: var(--spacing-sm) auto 0;
        max-width: 900px;
        opacity: 0.7;
        text-transform: none;
      }

      /* Responsive */
      @media (max-width: 900px) {
        .lf-tmj-container {
          flex-direction: column;
          align-items: center;
          padding: 60px 20px;
        }

        .lf-tmj-divider {
          height: 2px;
          width: 80%;
          margin: 30px auto;
        }

        .lf-tmj-section {
          width: 100%;
        }

        .lf-tmj-hours-section,
        .lf-tmj-started-section {
          flex: none;
          max-width: 500px;
          text-align: left;
        }

        .lf-tmj-started-section {
          text-align: center;
        }

        .lf-tmj-started-title,
        .lf-tmj-started-text {
          text-align: center;
        }
      }
    }
  }
</style>
