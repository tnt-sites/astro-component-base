---
import FixedTabs from "@components/navigation/fixed-tabs/FixedTabs.astro";
import fixedTabsData from "@data/fixedTabs.json";
import { normalizeLandingStyle } from "@layouts/landing/landingStyles";

const {
  landingStyle,
  tabs = fixedTabsData.tabs,
  class: className,
  _component,
  ...props
} = Astro.props as {
  landingStyle?: string;
  tabs?: any[];
  class?: string;
  _component?: string;
  [key: string]: any;
};

const resolvedLandingStyle = normalizeLandingStyle(landingStyle);
const combinedClassName = [
  "landing-fixed-tabs",
  `landing-fixed-tabs--${resolvedLandingStyle}`,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<FixedTabs tabs={tabs} class={combinedClassName} _component={_component} {...props} />
