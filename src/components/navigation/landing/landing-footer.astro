---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Button from "@core-elements/button/Button.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  logoSource,
  logoAlt = "Logo",
  siteName = "",
  sitename = "",
  contactTitle = "Contact Us",
  offices = [],
  socials = [],
  legalLinks = [],
  pageButtons = [],
  mapEmbedUrl = "",
  legalBlurb = "",
  class: className,
  ...htmlAttributes
} = Astro.props;

const normalizedOffices = Array.isArray(offices) ? offices : [];

const normalizedButtons = (Array.isArray(pageButtons) ? pageButtons : []).map((button: any) => ({
  ...button,
  text: typeof button?.text === "string" ? button.text : "",
}));

const normalizedSocials = Array.isArray(socials) ? socials : [];
const normalizedLegalLinks = Array.isArray(legalLinks) ? legalLinks : [];
const displaySiteName = siteName || sitename;
const copyYear = new Date().getFullYear();
const normalizedMapEmbedUrl =
  typeof mapEmbedUrl === "string" && mapEmbedUrl.trim().length > 0 ? mapEmbedUrl.trim() : "";
const normalizedLegalBlurb =
  typeof legalBlurb === "string" && legalBlurb.trim().length > 0 ? legalBlurb.trim() : "";

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};
---

<footer class:list={["landing-footer", className]} {...htmlAttributes}>
  <CustomSection maxContentWidth="2xl" paddingHorizontal="md" paddingVertical="xl">
    <div class="landing-footer-top">
      <a href="/" class="landing-footer-logo-link">
        <Image source={logoSource} alt={logoAlt} class="landing-footer-logo" editable={false} />
      </a>

      {
        normalizedButtons.length > 0 && (
          <ButtonGroup
            direction="row"
            align="center"
            class="landing-footer-buttons"
            buttonSections={normalizedButtons}
            editable={false}
          />
        )
      }
    </div>

    <div class="landing-footer-contact">
      <span class="landing-footer-title">{contactTitle}</span>
      {
        normalizedOffices.map((office: any) => (
          <div class="landing-footer-office">
            {office?.name && <span class="landing-footer-office-name">{office.name}</span>}

            {Array.isArray(office?.phones) &&
              office.phones.map((phone: any) =>
                phone?.display ? (
                  <a href={phone?.href || "#"} class="landing-footer-phone">
                    {phone?.label ? `${phone.label}: ` : ""}
                    {phone.display}
                  </a>
                ) : null
              )}

            {Array.isArray(office?.addresses) &&
              office.addresses.map((address: any) => {
                const formattedLines = formatAddressLines(address);

                return formattedLines.length > 0 ? (
                  <a
                    href={address?.mapUrl || "#"}
                    class="landing-footer-address"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {formattedLines.map((line: string, index: number) => (
                      <>
                        {line}
                        {index < formattedLines.length - 1 && <br />}
                      </>
                    ))}
                  </a>
                ) : null;
              })}
          </div>
        ))
      }

      {
        normalizedSocials.length > 0 && (
          <div class="landing-footer-socials">
            <ButtonGroup alignX="start">
              {normalizedSocials.map((social: any) => (
                <Button
                  variant="ghost"
                  size="lg"
                  iconName={social.icon}
                  link={social.link}
                  hideText="true"
                  aria-label={`Visit our ${social.icon} page`}
                  target="_blank"
                  rel="noopener noreferrer"
                />
              ))}
            </ButtonGroup>
          </div>
        )
      }
    </div>

    {
      normalizedMapEmbedUrl && (
        <div class="landing-footer-map-embed" aria-label="Map location">
          <iframe
            src={normalizedMapEmbedUrl}
            title="Office location map"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      )
    }

    <div class="landing-footer-legal">
      <span>
        &copy; {copyYear}
        {displaySiteName}
      </span>
      {
        normalizedLegalLinks.map((item: any) => (
          <a href={item?.path || "#"}>{item?.name || "Link"}</a>
        ))
      }
    </div>

    {normalizedLegalBlurb && <p class="landing-footer-legal-blurb">{normalizedLegalBlurb}</p>}
  </CustomSection>
</footer>

<style lang="pcss" is:global>
  @layer page-sections {
    .landing-footer {
      container-type: inline-size;

      &[data-fixed-tabs-active="true"] {
        @media (max-width: 1024px) {
          padding-bottom: calc(72px + env(safe-area-inset-bottom));
        }
      }

      .landing-footer-top {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);
        justify-content: space-between;
      }

      .landing-footer-logo-link {
        display: inline-flex;
      }

      .landing-footer-logo {
        margin: 0 !important;
      }

      .landing-footer-contact {
        margin-top: var(--spacing-md);
      }

      .landing-footer-title,
      .landing-footer-office-name,
      .landing-footer-phone,
      .landing-footer-address,
      .landing-footer-legal {
        color: var(--color-text);
      }

      .landing-footer-title,
      .landing-footer-office-name {
        display: block;
        font-weight: var(--font-weight-semibold);
      }

      .landing-footer-office {
        margin-top: var(--spacing-2xs);
      }

      .landing-footer-phone,
      .landing-footer-address,
      .landing-footer-legal a {
        display: inline-block;
        text-decoration: none;

        &:hover,
        &:focus-visible {
          color: var(--color-link-hover);
        }
      }

      .landing-footer-address {
        display: block;
        margin-top: var(--spacing-3xs);
      }

      .landing-footer-socials {
        margin-top: var(--spacing-xs);
      }

      .landing-footer-map-embed {
        margin-top: var(--spacing-md);

        iframe {
          aspect-ratio: 16 / 9;
          border: 0;
          border-radius: var(--radius-md);
          display: block;
          width: 100%;
        }
      }

      .landing-footer-legal {
        border-top: 1px solid var(--color-border);
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xs) var(--spacing-md);
        margin-top: var(--spacing-lg);
        padding-top: var(--spacing-sm);
      }

      .landing-footer-legal-blurb {
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
        line-height: var(--line-height-relaxed);
        margin-top: var(--spacing-sm);
      }
    }
  }
</style>
