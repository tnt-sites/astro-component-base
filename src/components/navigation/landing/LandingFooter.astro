---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@core-elements/image/Image.astro";

const {
  logoSource,
  logoAlt = "Logo",
  siteName = "",
  contactTitle = "Contact Us",
  offices = [],
  socials = [],
  legalLinks = [],
  pageButtons = [],
  mapEmbedUrl = "",
  legalBlurb = "",
  class: className,
  ...htmlAttributes
} = Astro.props;

const displaySiteName = siteName;
const copyYear = new Date().getFullYear();
const embedSrc = typeof mapEmbedUrl === "string" ? mapEmbedUrl.trim() : "";
const blurb = typeof legalBlurb === "string" ? legalBlurb.trim() : "";

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};

const getHoursSource = (source: any) => {
  if (!source || typeof source !== "object") {
    return [];
  }

  return source?.officeHours ?? source?.["office-hours"] ?? source?.office_hours ?? source?.hours ?? [];
};

const formatOfficeHours = (source: any) => {
  const rawHours = getHoursSource(source);
  const rawEntries = Array.isArray(rawHours)
    ? rawHours
    : rawHours && typeof rawHours === "object"
      ? Object.entries(rawHours).map(([day, value]: [string, any]) => {
          if (typeof value === "string") {
            return { day, hours: value };
          }

          if (value && typeof value === "object") {
            return { _day: day, ...value };
          }

          return null;
        })
      : [];

  return rawEntries
    .map((entry: any) => {
      if (typeof entry === "string") {
        const line = entry.trim();

        return line.length > 0
          ? { day: "", hours: line, note: "" }
          : null;
      }

      if (!entry || typeof entry !== "object") {
        return null;
      }

      const day =
        typeof entry?.day === "string"
          ? entry.day.trim()
          : typeof entry?.label === "string"
            ? entry.label.trim()
            : typeof entry?._day === "string"
              ? entry._day.trim()
              : "";
      const hours =
        typeof entry?.hours === "string"
          ? entry.hours.trim()
          : typeof entry?.time === "string"
            ? entry.time.trim()
            : typeof entry?.value === "string"
              ? entry.value.trim()
            : typeof entry?.display === "string"
              ? entry.display.trim()
              : "";
      const note =
        typeof entry?.note === "string"
          ? entry.note.trim()
          : typeof entry?.hoursNote === "string"
            ? entry.hoursNote.trim()
            : typeof entry?.["hours-note"] === "string"
              ? entry["hours-note"].trim()
              : typeof entry?.details === "string"
                ? entry.details.trim()
              : "";

      if (!day && !hours && !note) {
        return null;
      }

      return { day, hours, note };
    })
    .filter(Boolean);
};
---

<footer class:list={["landing-footer", className]} {...htmlAttributes}>
  <CustomSection maxContentWidth="2xl" paddingHorizontal="md" paddingVertical="xl">
    <div class="footer-content block lg:flex justify-around items-center">

              <a href="/" class="landing-footer-logo-link">
        <Image source={logoSource} alt={logoAlt} class="landing-footer-logo" editable={false} />
      </a>


          <div class="landing-footer-contact">
      <span class="fo-title">{contactTitle}</span>
      {
        offices.map((office: any) => (
          <div class="landing-footer-office">
            {office?.name && <span class="landing-footer-office-name">{office.name}</span>}

            {Array.isArray(office?.phones) &&
              office.phones.map((phone: any) =>
                phone?.display ? (
                  <a href={phone?.href || "#"} class="pho">
                    {phone?.label ? `${phone.label}: ` : ""}
                    {phone.display}
                  </a>
                ) : null
              )}

            {(() => {
              const addresses = Array.isArray(office?.addresses) ? office.addresses : [];
              const hasAddressSpecificHours = addresses.some(
                (address: any) => formatOfficeHours(address).length > 0
              );
              const officeHours = formatOfficeHours(office);

              return (
                <>
                  {addresses.map((address: any) => {
                    const formattedLines = formatAddressLines(address);
                    const addressHours = formatOfficeHours(address);
                    const hoursToRender =
                      addressHours.length > 0
                        ? addressHours
                        : hasAddressSpecificHours
                          ? []
                          : officeHours;

                    return (
                      <>
                        {formattedLines.length > 0 ? (
                          <a
                            href={address?.mapUrl || "#"}
                            class="phy"
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {formattedLines.map((line: string, index: number) => (
                              <>
                                {line}
                                {index < formattedLines.length - 1 && <br />}
                              </>
                            ))}
                          </a>
                        ) : null}

                        {hoursToRender.length > 0 && (
                          <>
                            <span class="fo-title mt-4">Office Hours</span>
                            <div class="office-hours office-hours--left">
                              <div class="office-hours-list">
                                {hoursToRender.map((hoursItem: any) => (
                                  <div class="office-hours-row">
                                    <div class="office-hours-line">
                                      {hoursItem.day && (
                                        <span class="office-hours-day">{hoursItem.day}</span>
                                      )}
                                      <span class="office-hours-time">{hoursItem.hours}</span>
                                    </div>
                                    {hoursItem.note && (
                                      <small class="office-hours-note">{hoursItem.note}</small>
                                    )}
                                  </div>
                                ))}
                              </div>
                            </div>
                          </>
                        )}
                      </>
                    );
                  })}

                  {addresses.length === 0 && officeHours.length > 0 && (
                    <>
                      <span class="fo-title mt-4">Office Hours</span>
                      <div class="office-hours office-hours--left">
                        <div class="office-hours-list">
                          {officeHours.map((hoursItem: any) => (
                            <div class="office-hours-row">
                              <div class="office-hours-line">
                                {hoursItem.day && (
                                  <span class="office-hours-day">{hoursItem.day}</span>
                                )}
                                <span class="office-hours-time">{hoursItem.hours}</span>
                              </div>
                              {hoursItem.note && (
                                <small class="office-hours-note">{hoursItem.note}</small>
                              )}
                            </div>
                          ))}
                        </div>
                      </div>
                    </>
                  )}
                </>
              );
            })()}
          </div>
        ))
      }

      <!-- {
        socials.length > 0 && (
          <div class="landing-footer-socials">
            <ButtonGroup alignX="start">
              {socials.map((social: any) => (
                <Button
                  variant="ghost"
                  size="lg"
                  iconName={social.icon}
                  link={social.link}
                  hideText="true"
                  aria-label={`Visit our ${social.icon} page`}
                  target="_blank"
                  rel="noopener noreferrer"
                />
              ))}
            </ButtonGroup>
          </div>
        )
      } -->
    </div>




        {
      embedSrc && (
        <div class="landing-footer-map-embed" aria-label="Map location">
          <iframe
            src={embedSrc}
            title="Office location map"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
      )
    }
    </div>





    <div class="copy uppercase letter-spacing-widest text-center">
      <span>
        &copy; {copyYear}
        {displaySiteName}
      </span>

                 <br class="inline lg:hidden" />
            <span class="mx-2 hidden lg:inline-block">|</span>
      {
        legalLinks.map((item: any) => (
          <a href={item?.path || "#"}>{item?.name || "Link"}</a> <span class="mx-2">|</span>
        ))
      }
      <br class="inline lg:hidden" />
      Site designed and maintained by <a href="https://www.tntdental.com" target="blank">TNT Dental</a>


          {
      blurb && (
        <p class="copy-blurb uppercase text-center mt-12">
          {blurb}
        </p>
      )
    }
    </div>


  </CustomSection>
</footer>

<style lang="pcss" is:global>
  @layer page-sections {
    .landing-footer {
      background-color: var(--color-bg-brand-secondary);
      container-type: inline-size;

      .content{
        padding: var(--spacing-lg) 0 0;
        max-width: 100%;
      }

      &[data-fixed-tabs-active="true"] {
        @media (max-width: 1024px) {
          padding-bottom: calc(72px + env(safe-area-inset-bottom));
        }
      }

      .landing-footer-top {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);
        justify-content: space-between;
      }

      .landing-footer-logo-link {
        display: inline-flex;
      }

      .footer-content{max-width: 1150px; margin: 0 auto; padding: 50px 20px;}

      .landing-footer-logo {
        margin: 0 !important;
      }

      .landing-footer-contact {
        margin-top: var(--spacing-md);
        margin-bottom: var(--spacing-md);
        flex: 0 1 350px;
      }

      .fo-title,
      .landing-footer-office-name,
      .pho,
      .phy,
      .copy {
        color:#fff;
      }

      .pho{
        font-size: var(--font-size-xl);
        font-weight: strong;
      }

      .fo-title,
      .landing-footer-office-name {
        display: block;
        font-weight: var(--font-weight-semibold);
      }

      .landing-footer-office {
        margin-top: var(--spacing-2xs);
      }

      .pho,
      .phy,
      .copy a {
        display: inline-block;
        text-decoration: none;

        &:hover,
        &:focus-visible {
          color: var(--color-link-hover);
        }
      }

      .phy {
        display: block;
        margin-top: var(--spacing-3xs);
      }

      .office-hours {
        --office-hours-color: #fff;
        --office-hours-day-color: #fff;
        --office-hours-note-color: rgba(255, 255, 255, 0.75);
        margin-top: var(--spacing-2xs);
      }

      .landing-footer-socials {
        margin-top: var(--spacing-xs);
      }

      .landing-footer-map-embed {
        flex: 0 1 415px;
        iframe {
          min-height: 305px;
          width: 100%;
          border: 0;
          border-radius: var(--radius-md);
        }
      }

      .copy {
        background-color: #000;
        gap: var(--spacing-xs) var(--spacing-md);
        margin-top: var(--spacing-lg);
        padding-top: var(--spacing-sm);
        padding: 20px;
      }

      .copy-blurb {
        color: #fff;;
        font-size: var(--font-size-sm);
        line-height: var(--line-height-relaxed);
        max-width: 1150px; margin: 0 auto;
        margin-top: var(--spacing-sm);
        margin-bottom: 0;

      }
    }
  }
</style>
