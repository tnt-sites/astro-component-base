---
import MainNavigation from "@components/navigation/main-nav/MainNav.astro";
import { normalizeLandingStyle } from "@layouts/landing/landingStyles";

const {
  landingStyle,
  class: className,
  ...props
} = Astro.props as {
  landingStyle?: string;
  class?: string;
  [key: string]: any;
};

const resolvedLandingStyle = normalizeLandingStyle(landingStyle);
const combinedClassName = ["landing-header", `landing-header--${resolvedLandingStyle}`, className]
  .filter(Boolean)
  .join(" ");
---

<MainNavigation {...props} class={combinedClassName} />
