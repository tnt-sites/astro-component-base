---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  logoSource,
  logoAlt = "Logo",
  pageButtons = [],
  offices = [],
  id: elementId,
  class: className,
  ...htmlAttributes
} = Astro.props as {
  logoSource?: string;
  logoAlt?: string;
  pageButtons?: any[];
  offices?: any[];
  id?: string;
  class?: string;
  [key: string]: any;
};

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};

const buttons = pageButtons.map((button: any) => ({
  ...button,
  text: typeof button?.text === "string" ? button.text : "",
}));
---

<CustomSection
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="none"
  id={elementId || undefined}
  class:list={["landing-header-split", className]}
  {...htmlAttributes}
>
  <div class="landing-header-split-inner">
    <div class="landing-header-split-contact">
      {
        offices.map((office: any) => (
          <div class="landing-header-split-office">
            {Array.isArray(office?.phones) &&
              office.phones.map((phone: any) =>
                phone?.display ? (
                  <a href={phone?.href || "#"} class="landing-header-split-phone">
                    {phone?.label ? `${phone.label}: ` : ""}
                    {phone.display}
                  </a>
                ) : null
              )}

            {Array.isArray(office?.addresses) &&
              office.addresses.map((address: any) => {
                const formattedLines = formatAddressLines(address);

                return formattedLines.length > 0 ? (
                  <a
                    href={address?.mapUrl || "#"}
                    class="landing-header-split-address"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {formattedLines.map((line: string, index: number) => (
                      <>
                        {line}
                        {index < formattedLines.length - 1 && <br />}
                      </>
                    ))}
                  </a>
                ) : null;
              })}
          </div>
        ))
      }
    </div>

    <a class="landing-header-split-logo-link" href="/">
      <Image source={logoSource} class="landing-header-split-logo" alt={logoAlt} editable={false} />
    </a>

    {
      buttons.length > 0 && (
        <div class="landing-header-split-buttons">
          <ButtonGroup
            direction="row"
            align="center"
            class="landing-header-split-button-group"
            buttonSections={buttons}
            editable={false}
          />
        </div>
      )
    }
  </div>
</CustomSection>

<style lang="pcss" is:global>
  @layer page-sections {
    .landing-header-split {
      .landing-header-split-inner {
        align-items: center;
        display: grid;
        gap: var(--spacing-md);
        grid-template-columns: 1fr;
        padding-block: var(--spacing-sm);

        @media (min-width: 900px) {
          grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        }
      }

      .landing-header-split-contact {
        text-align: left;

        @media (min-width: 900px) {
          justify-self: start;
        }
      }

      .landing-header-split-logo-link {
        display: inline-flex;
        justify-self: center;
        order: -1;

        @media (min-width: 900px) {
          order: 0;
        }
      }

      .landing-header-split-logo {
        margin: 0 !important;
      }

      .landing-header-split-phone,
      .landing-header-split-address {
        color: var(--color-text);
        display: block;
        text-decoration: none;

        &:hover,
        &:focus-visible {
          color: var(--color-link-hover);
        }
      }

      .landing-header-split-phone {
        font-weight: var(--font-weight-semibold);
      }

      .landing-header-split-address {
        margin-top: var(--spacing-2xs);
      }

      .landing-header-split-buttons {
        @media (min-width: 900px) {
          justify-self: end;
        }
      }

      .landing-header-split-button-group {
        justify-content: flex-start;

        @media (min-width: 900px) {
          justify-content: flex-end;
        }
      }
    }
  }
</style>
