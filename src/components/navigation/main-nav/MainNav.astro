---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Bar from "@components/navigation/bar/Bar.astro";
import Mobile from "@components/navigation/mobile/Mobile.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  logoSource,
  logoAlt = "logo",
  navData = [],
  buttonSections = [],
  socials = [],
  class: className,
  offices = [],
  legalLinks = [],
  phoneText = "",
  phoneHref = "",
  addressHref = "",
  addressLines = [],
  emailHref = "",
  emailText = [],
  officeHoursTitle = "Office Hours",
  officeHours = [],
  officeHoursNote = "",
  officeHoursNotes = [],
  _component,
  ...htmlAttributes
} = Astro.props;

const defaultSearchButtonSections = [
  {
    _component: "building-blocks/core-elements/button",
    text: "Search",
    hideText: true,
    link: "/search/",
    iconName: "magnifying-glass",
    iconPosition: "before",
    variant: "ghost",
    size: "lg",
    width: "xs",
  },
];

const resolvedSearchButtonSections =
  Array.isArray(buttonSections) && buttonSections.length > 0
    ? buttonSections
    : defaultSearchButtonSections;

const sanitizeButtonSection = (button: any) => ({
  ...button,
  text: typeof button?.text === "string" ? button.text : "",
});

const normalizedSearchButtonSections = resolvedSearchButtonSections.map((button: any) =>
  sanitizeButtonSection(button)
);

const mobileNavData = [
  ...navData,
  ...normalizedSearchButtonSections.map((button: any) => ({
    name: button.text || "Button",
    path: button.link || button.href || "#",
    children: [],
  })),
];

const normalizedOffices =
  Array.isArray(offices) && offices.length > 0
    ? offices
    : [
        {
          name: "",
          addresses:
            Array.isArray(addressLines) && addressLines.length > 0
              ? [
                  {
                    lines: addressLines,
                    mapUrl: addressHref || "",
                  },
                ]
              : [],
          phones: phoneText
            ? [
                {
                  display: phoneText,
                  href: phoneHref || "",
                },
              ]
            : [],
          officeHours,
          officeHoursNote,
          officeHoursNotes,
          socials,
        },
      ];

const sharedSocials =
  Array.isArray(socials) && socials.length > 0
    ? socials
    : Array.isArray(normalizedOffices[0]?.socials)
      ? normalizedOffices[0].socials
      : [];

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};
---

<CustomSection
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="none"
  class:list={["main-nav", className]}
  {...htmlAttributes}
>
  <div class="hd-content">
    <a class="logo-link" href="/">
      <Image source={logoSource} class="main-nav-logo" alt={logoAlt} editable={false} />
    </a>
    <!-- Desktop Nav -->
    <div class="hd-right">
      <!-- Phone and Address -->
      <div class="hd-info">
        {
          normalizedOffices.map((office: any) => (
            <>
              {Array.isArray(office?.phones) &&
                office.phones.map((phone: any) =>
                  phone?.display ? (
                    <a href={phone?.href || "#"} class="pho">
                      {phone?.label ? `${phone.label}: ` : ""}
                      {phone.display}
                    </a>
                  ) : null
                )}

              {Array.isArray(office?.addresses) &&
                office.addresses.map((address: any) => {
                  const formattedLines = formatAddressLines(address);

                  return formattedLines.length > 0 ? (
                    <a
                      href={address?.mapUrl || "#"}
                      class="phy"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {formattedLines.map((line: string, index: number) => (
                        <>
                          {line}
                          {index < formattedLines.length - 1 && <br />}
                        </>
                      ))}
                    </a>
                  ) : null;
                })}
            </>
          ))
        }
      </div>
      <div class="hd-nav">
        <div class="nav-end">
          <Bar navData={navData} class="desktop-main-nav" />

          <ButtonGroup
            direction="row"
            align="center"
            class="desktop-button-group"
            buttonSections={normalizedSearchButtonSections}
            editable={false}
          />
        </div>
      </div>
      <!-- End Desktop Nav -->
    </div>
  </div>
  <!-- Mobile Nav -->
  <Mobile
    logoSource={logoSource}
    logoAlt={logoAlt}
    navData={mobileNavData}
    class="mobile-main-nav"
    normalizedOffices={normalizedOffices}
    sharedSocials={sharedSocials}
  />
  <!-- End Mobile Nav -->
</CustomSection>

<!-- Adds --site-header-height CSS variable based on header height. Works with multiple screen sizes. -->
<script>
  const initMainNavHeaderHeight = () => {
    document.querySelectorAll(".main-nav").forEach((mainNav) => {
      if (mainNav.getAttribute("data-header-height-initialized") === "true") return;

      const syncHeaderHeight = () => {
        document.documentElement.style.setProperty(
          "--site-header-height",
          `${Math.round(mainNav.getBoundingClientRect().height)}px`
        );
      };

      syncHeaderHeight();

      if (typeof ResizeObserver !== "undefined") {
        const resizeObserver = new ResizeObserver(syncHeaderHeight);
        resizeObserver.observe(mainNav);
      }

      mainNav.setAttribute("data-header-height-initialized", "true");
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMainNavHeaderHeight);
  } else {
    initMainNavHeaderHeight();
  }
</script>

<style lang="pcss" is:global>
  @layer page-sections {
    .main-nav {
      z-index: var(--layer-2);
      background-color: var(--color-bg); 
      padding-block: var(--spacing-md);
      position: sticky; 
      top: 0;

      .desktop-main-nav.bar,
      .desktop-button-group.button-group {
        @container (max-width: 768px) {
          display: none;
        }
      }

      .main-nav-logo {
        margin-top: 0 !important;
      }

      .nav-hamburger.mobile-button {
        @container (min-width: 769px) {
          display: none;
        }
      }

      > .outer-content .hd-content {
        align-items: center;
        container-type: inline-size;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);

        > a > .image img {
          height: 1.8em;
          max-width: min(20em, 100%);
          width: auto;
        }

        .button-group {
          margin-top: 0;
        }
      }

      > .outer-content .hd-content .hd-right {
        display: flex;
        flex: 0 1 700px;
        flex-direction: column;
        gap: var(--spacing-sm);
        margin-left: auto;
        align-items: end;
        margin-right: 20px;
      }

      > .outer-content .hd-content .hd-actions {
        align-items: center;
        display: flex;
        gap: var(--spacing-sm);
        justify-content: flex-end;
      }

      > .outer-content .hd-content .nav-end {
        align-items: center;
        display: inline-flex;
        flex: 0 0 auto;
        gap: var(--spacing-xs);
        justify-content: flex-end;
      }

      > .outer-content .hd-content .nav-end > .desktop-main-nav.bar {
        flex: 0 1 auto;
      }

      > .outer-content .hd-content .nav-end > .desktop-button-group.button-group {
        flex: 0 0 30px;
        margin-top: 0;
        width: auto;
      }
    }

    .hd-info{display: flex; justify-content: space-between; align-items: center;}
    .phy{display: block; text-transform: uppercase; letter-spacing: 2px; color: var(--color-text); line-height: 1; transition: .3s;}
    .pho{font-weight: var(--font-weight-bold); color: var(--color-brand); font-size: var(--font-size-2xl); line-height: 1; margin-right: 20px;  transition: .3s;}

    .pho:hover, .phy:hover{color: var(--color-brand-secondary)}

    .mobile-nav-button{min-width: 10px;border-radius: 0; border: none; height: 70px; width: 70px; background-color: var(--color-brand); color: #fff; display: flex; align-items: center; justify-content: center;}
    .nav-hamburger .mobile-nav-button .icon {
      font-size: var(--font-size-4xl);
    }

    .nav-hamburger .mobile-nav-button .icon svg path {
      stroke-width: 2.25;
    }

    .mobile-close .mobile-nav-button .icon {
      font-size: var(--font-size-4xl);
    }

    .mobile-close .mobile-nav-button .icon svg path {
      stroke-width: 2.25;
    }

    .mobile-nav-close {}


    @media (max-width: 1024px) {
      .main-nav{padding: 0;}
      .main-nav > .outer-content > .content {
        align-items: center;
        display: flex;
        gap: var(--spacing-sm);
        justify-content: space-between;
        padding-right: 0;
      }

      .main-nav > .outer-content .hd-content {
        align-items: center;
        display: flex;
        flex: 1 1 auto;
        min-width: 0;
      }

      .main-nav > .outer-content .hd-content .logo-link {
        display: block;
        flex: 0 0 auto;
      }

      .main-nav > .outer-content .hd-content .logo-link .image img {
        display: block;
      }

      .hd-info, .top-bar{display: none;}
      .main-nav > .outer-content .hd-content .hd-right {display: none;}
    }
  }

</style>
