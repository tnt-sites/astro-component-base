---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Button from "@core-elements/button/Button.astro";
import Divider from "@core-elements/divider/Divider.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  links = [],
  socials = [],
  siteName = "",
  offices = [],
  legalLinks = [],
  contactTitle = "Contact Us",
  phoneText = "",
  phoneHref = "",
  addressHref = "",
  addressLines = [],
  emailHref = "",
  emailText = [],
  officeHoursTitle = "Office Hours",
  officeHours = [],
  officeHoursNote = "",
  officeHoursNotes = [],
  mapEmbedUrl = "",
  legalBlurb = "",
  logoSource,
  logoAlt,
  _component,
  ...htmlAttributes
} = Astro.props;

const resolvedOffices =
  Array.isArray(offices) && offices.length > 0
    ? offices
    : [
        {
          name: "",
          addresses:
            Array.isArray(addressLines) && addressLines.length > 0
              ? [
                  {
                    lines: addressLines,
                    mapUrl: addressHref || "",
                  },
                ]
              : [],
          phones: phoneText
            ? [
                {
                  display: phoneText,
                  href: phoneHref || "",
                },
              ]
            : [],
          officeHours,
          officeHoursNote,
          officeHoursNotes,
          socials,
        },
      ];

const displaySiteName = siteName;
const sharedSocials =
  Array.isArray(socials) && socials.length > 0
    ? socials
    : Array.isArray(resolvedOffices[0]?.socials)
      ? resolvedOffices[0].socials
      : [];

const formatAddressLines = (address: any) => {
  const lineItems = Array.isArray(address?.lines) ? address.lines : [];
  const stateAndPostal = [address?.state, address?.postalCode].filter(Boolean).join(" ");
  const cityStatePostal = [address?.city, stateAndPostal].filter(Boolean).join(", ");
  const locationLine = [cityStatePostal, address?.country].filter(Boolean).join(", ");

  return [...lineItems, locationLine].filter(
    (line) => typeof line === "string" && line.trim().length > 0
  );
};

const getOfficeHoursGeneralNotes = (office: any) => {
  const notes = [
    office?.officeHoursNote,
    office?.["office-hours-note"],
    ...(Array.isArray(office?.officeHoursNotes) ? office.officeHoursNotes : []),
    ...(Array.isArray(office?.["office-hours-notes"]) ? office["office-hours-notes"] : []),
  ];

  return notes.filter((note) => typeof note === "string" && note.trim().length > 0);
};

const copyYear = new Date().getFullYear();
const embedSrc = typeof mapEmbedUrl === "string" ? mapEmbedUrl.trim() : "";
const blurb = typeof legalBlurb === "string" ? legalBlurb.trim() : "";
---

<footer class="footer" {...htmlAttributes}>
  <CustomSection maxContentWidth="2xl" paddingHorizontal="md" paddingVertical="2xl">
    <div class="footer-content">
      <div class="content-container">
        <a href="/">
          <Image source={logoSource} alt={logoAlt} class="footer-logo" editable={false} />
        </a>
      </div>
      <!-- <div class="content-container">
        <Bar navData={links} />
      </div> -->
    </div>

    <div id="fo-content" class="fo-content block lg:flex justify-around items-start text-center">
      <div class="fo-info">
        <span class="fo-title">{contactTitle}</span>
        {
          resolvedOffices.map((office: any) => (
            <div class="office-block">
              {office?.name && <span class="office-name">{office.name}</span>}
              {Array.isArray(office?.phones) &&
                office.phones.map((phone: any) =>
                  phone?.display ? (
                    <a href={phone?.href || "#"} class="pho">
                      {phone?.label ? `${phone.label}: ` : ""}
                      {phone.display}
                    </a>
                  ) : null
                )}
              {Array.isArray(office?.emails) &&
                office.emails.map((email: any) =>
                  email?.display ? (
                    <a href={email?.href || "#"} class="pho">
                      {email?.label ? `${email.label}: ` : ""}
                      {email.display}
                    </a>
                  ) : null
                )}
              {Array.isArray(office?.addresses) &&
                office.addresses.map((address: any) => {
                  const formattedLines = formatAddressLines(address);

                  return formattedLines.length > 0 ? (
                    <a
                      href={address?.mapUrl || "#"}
                      class="phy"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {formattedLines.map((line: string, index: number) => (
                        <>
                          {line}
                          {index < formattedLines.length - 1 && <br />}
                        </>
                      ))}
                    </a>
                  ) : null;
                })}
            </div>
          ))
        }

        {
          sharedSocials.length > 0 && (
            <div class="social">
              <ButtonGroup alignX="center">
                {sharedSocials.map((social: any) => (
                  <Button
                    variant="ghost"
                    size="lg"
                    iconName={social.icon}
                    link={social.link}
                    hideText="true"
                    aria-label={`Visit our ${social.icon} page`}
                    target="_blank"
                    rel="noopener noreferrer"
                  />
                ))}
              </ButtonGroup>
            </div>
          )
        }
      </div>

      <div class="fo-hours">
        <span class="fo-title">{officeHoursTitle}</span>
        {
          resolvedOffices.map((office: any) => (
            <div class="office-hours">
              {/* {office?.name && <span class="office-name">{office.name}</span>} */}
              <div class="office-hours-list">
                {(office?.officeHours || []).map((item: any) => (
                  <div class="office-hours-row">
                    <div class="office-hours-line">
                      <span class="office-hours-day">{item.day || ""}</span>
                      <span class="office-hours-time">{item.hours || ""}</span>
                    </div>
                    {(item?.note || item?.hoursNote || item?.["hours-note"]) && (
                      <small class="office-hours-note">
                        {item?.note || item?.hoursNote || item?.["hours-note"]}
                      </small>
                    )}
                  </div>
                ))}
              </div>
              {getOfficeHoursGeneralNotes(office).length > 0 && (
                <div class="office-hours-general-notes">
                  {getOfficeHoursGeneralNotes(office).map((note: string) => (
                    <small class="office-hours-general-note">{note}</small>
                  ))}
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>

    {
      embedSrc && (
        <div class="footer-map-embed" aria-label="Map location">
          <iframe
            src={embedSrc}
            title="Office location map"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
      )
    }

    <Divider />

    <div class="footer-content">
      <div class="content-container">
        <div class="footer-legal-text" id="copy">
          <span class="footer-legal-line footer-legal-line--primary">
            &copy;<span class="inline" id="copyDate">{copyYear}</span>
            {displaySiteName}
          </span>
          {
            legalLinks.length > 0 && (
              <span class="footer-legal-separator" aria-hidden="true">
                |
              </span>
            )
          }
          {
            legalLinks.length > 0 && (
              <span class="footer-legal-line footer-legal-line--links">
                {legalLinks.map((item: any, index: number) => (
                  <>
                    <a href={item.path || "#"}>{item.name || "Link"}</a>
                    {index < legalLinks.length - 1 && <span class="mx-2">|</span>}
                  </>
                ))}
              </span>
            )
          }
          <span class="footer-legal-separator" aria-hidden="true">|</span>
          <span class="footer-legal-line footer-legal-line--credit">
            Site designed and maintained by{" "}
            <a href="https://www.tntdental.com" target="_blank" rel="noopener noreferrer">
              TNT Dental
            </a>
          </span>
        </div>
        {blurb && <p class="footer-legal-blurb">{blurb}</p>}
      </div>
    </div>
  </CustomSection>
</footer>

<style lang="pcss" is:global>
  @layer page-sections {
    .footer {
      container-type: inline-size;

      &[data-fixed-tabs-active="true"] {
        @media (max-width: 1024px) {
          padding-bottom: calc(72px + env(safe-area-inset-bottom));
        }
      }

      .button-group {
        &.align-end {
          @container (max-width: 599px) {
            justify-content: center;
          }
        }


      }

      .footer-content {
        @container (min-width: 600px) {
          align-items: center;
          display: flex;
          flex-wrap: wrap;
          justify-content: space-between;
        }

        .content-container {
          flex: 1;

          > a {
            display: block;
            text-align: center;
          }
        }
      }

      .footer-map-embed {
        margin-block: var(--spacing-lg);

        iframe {
          aspect-ratio: 16 / 9;
          border: 0;
          border-radius: var(--radius-md);
          display: block;
          width: 100%;
        }
      }

      .footer-legal-text {
        color: var(--color-text-muted);
        text-align: center;
        @container (min-width: 600px) {
          text-align: start;
        }
      }

      .footer-legal-blurb {
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
        line-height: var(--line-height-relaxed);
        margin-top: var(--spacing-sm);
        text-align: center;

        @container (min-width: 600px) {
          text-align: start;
        }
      }

      .footer-logo {
        flex-shrink: 0;
        margin-top: 0 !important;

        img {
          margin: 0 auto 30px;
          width: auto;
        }
      }

      .bar .bar-list {
        flex-flow: column wrap;
        @container (min-width: 600px) {
          flex-direction: row;
          justify-content: end;
        }
      }

      .fo-content {
        margin-block: var(--spacing-lg);

        @container (min-width: 700px) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .fo-title {
          color: var(--color-text-strong);
          display: block;
          font-weight: var(--font-weight-semibold);
          margin-bottom: var(--spacing-sm);
          text-align: center;
        }

        .office-block,
        .office-hours-block {
          margin-bottom: var(--spacing-md);
        }

        .office-name {
          color: var(--color-text-strong);
          display: block;
          font-weight: var(--font-weight-semibold);
          margin-bottom: var(--spacing-xs);
        }

        .pho,
        .phy {
          color: var(--color-text);
          display: block;
          margin-bottom: var(--spacing-sm);
          text-decoration: none;

          &:hover,
          &:focus-visible {
            color: var(--color-link-hover);
          }
        }

        .office-hours {
          display: table;
          margin: 10px auto;
          text-align: left;

          .fo-title { text-align: center; }
        }

        .social {
          margin-top: var(--spacing-sm); 

          .button{min-width: auto;}
        }
      }
    }

    #copy {
      font-size: var(--font-size-sm);
      line-height: 1.5;
      padding: var(--spacing-md) var(--spacing-sm);
      text-align: center;

      .footer-legal-line {
        display: inline;
      }

      .footer-legal-separator {
        display: inline;
        margin: 0 0.5rem;
      }

      a {
        color: var(--color-link);

        &:hover,
        &:focus-visible {
          color: var(--color-link-hover);
        }
      }

      @media (max-width: 1024px) {
        .footer-legal-line {
          display: block;
        }

        .footer-legal-line + .footer-legal-line {
          margin-top: 0.25rem;
        }

        .footer-legal-separator {
          display: none;
        }
      }
    }
  }
</style>
