---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import ServicesGridItem from "./ServicesGridItem.astro";

type ServiceLink = {
  _component?: string;
  label?: string;
  text?: string;
  href?: string;
};

type ServiceItem = {
  _component?: string;
  imageSource?: string;
  imageAlt?: string;
  title?: string;
  href?: string;
  wide?: boolean | string;
  links?: ServiceLink[];
};

type ServicesGridCta = {
  enabled?: boolean | string;
  id?: string;
  href?: string;
  heading?: string;
  buttonText?: string;
  wide?: boolean | string;
};

const {
  heading = "",
  services = [],
  ctaCard,
  backgroundColor = "base",
  id = "",
  backgroundImage,
  class: className,
  editable = true,
  _component,
  ...rest
} = Astro.props;

const isTrue = (value: unknown) =>
  typeof value === "string" ? value.trim().toLowerCase() === "true" : !!value;

const cleanText = (value: unknown, fallback = "") =>
  typeof value === "string" && value.trim().length > 0 ? value.trim() : fallback;

const stripP = (value: string) =>
  value
    .trim()
    .replace(/<\/p>\s*<p(?:\s[^>]*)?>/gi, "<br>")
    .replace(/^<p(?:\s[^>]*)?>/i, "")
    .replace(/<\/p>\s*$/i, "");

const normalizeLabel = (link: ServiceLink) => cleanText(link.label, cleanText(link.text));

const normalizeLinks = (links: unknown) =>
  Array.isArray(links)
    ? links
        .filter((link): link is ServiceLink => !!link && typeof link === "object")
        .map((link) => ({
          label: normalizeLabel(link),
          href: cleanText(link.href, "#"),
        }))
        .filter((link) => link.label.length > 0)
    : [];

const normalizedServices = Array.isArray(services)
  ? services
      .filter((service): service is ServiceItem => !!service && typeof service === "object")
      .map((service) => ({
        title:
          typeof service.title === "string" && service.title.trim().length > 0
            ? stripP(service.title)
            : "Service",
        href: cleanText(service.href, "#"),
        imageSource: cleanText(service.imageSource),
        imageAlt: cleanText(service.imageAlt),
        wide: isTrue(service.wide),
        links: normalizeLinks(service.links),
      }))
  : [];

const rawCtaCard = !!ctaCard && typeof ctaCard === "object" ? (ctaCard as ServicesGridCta) : {};
const normalizedCtaCard = {
  enabled: rawCtaCard.enabled === undefined ? false : isTrue(rawCtaCard.enabled),
  id:
    cleanText(rawCtaCard.id, "all").replace(/^#/, "") || "all",
  href: cleanText(rawCtaCard.href, "request-an-appointment.html"),
  heading:
    typeof rawCtaCard.heading === "string" && rawCtaCard.heading.trim().length > 0
      ? stripP(rawCtaCard.heading)
      : "Get Started Now",
  buttonText: cleanText(rawCtaCard.buttonText, "Request an Appointment"),
  wide: rawCtaCard.wide === undefined ? true : isTrue(rawCtaCard.wide),
};

const hasServices = normalizedServices.length > 0;
const hasHeading = typeof heading === "string" && heading.trim().length > 0;
const hasCtaCard = normalizedCtaCard.enabled;

const servicesArrayDataAttributes = editable
  ? {
      "data-editable": "array",
      "data-component-key": "_component",
      "data-id-key": "_component",
      "data-prop": "services",
    }
  : {};

if (!_component && !hasHeading && !hasServices && !hasCtaCard) {
  return;
}

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["services-grid", className]}
  id={id || undefined}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  backgroundImage={backgroundImage}
  {...htmlAttributes}
>
  {
    (hasServices || hasCtaCard) && (
      <div class="services-grid-items" {...servicesArrayDataAttributes}>
        {normalizedServices.map((service) => (
          <editable-array-item
            data-component="page-sections/ctas/services-grid/services-grid-item"
            class:list={["services-grid-item", service.wide && "is-wide"]}
          >
            <ServicesGridItem {...service} editable={editable} />
          </editable-array-item>
        ))}

        {hasCtaCard && (
          <div
            id={normalizedCtaCard.id}
            class:list={[
              "services-grid-item",
              "services-grid-cta",
              normalizedCtaCard.wide && "is-wide",
            ]}
          >
            <a href={normalizedCtaCard.href}>
              <div class="services-grid-cta-heading h2">
                <Fragment set:html={normalizedCtaCard.heading} />
              </div>
              <div class="services-grid-cta-button btn btn-white">
                {normalizedCtaCard.buttonText}
              </div>
            </a>
          </div>
        )}
      </div>
    )
  }
</CustomSection>

<style lang="pcss" is:global>
  @layer page-sections {
    .services-grid {
      position: relative;

      .services-grid-heading {
        margin-top: 0;
      }

      .services-grid-items {
        align-items: stretch;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
        margin: 40px auto 0;
      }

      .services-grid-items > editable-array-item,
      .services-grid-items > .services-grid-item {
        background-color: #fff;
        box-shadow: 0 3px 6px rgb(0 0 0 / 60%);
        display: flex;
        flex-direction: column;
        flex: 0 1 360px;
        overflow: hidden;
      }

      .services-grid-items > editable-array-item.is-wide,
      .services-grid-items > .services-grid-item.is-wide {
        flex: 1 1 min(100%, 820px);
      }

      .services-grid-figure {
        margin: 0;
        transition: 0.4s all;

        img {
          display: block;
          width: 100%;
        }

        .image{margin-top: 0;}
      }

      .services-grid-content {
        padding: 0 20px 20px;
      }

      .services-grid-title {
        display: block;
        font-family: var(--font-heading);
        font-size: clamp(1.75rem, 2.8vw, 1.875rem);
        line-height: 1.2;
        margin: 20px 0 0;
        text-align: center;
        text-transform: none;

        span {
          display: block;
          font-size: 18px;
        }

        a {
          color: var(--color-text);
          text-decoration: none;
        }
      }

      .services-grid-title:hover a,
      .services-grid-title:focus-within a {
        color: var(--color-brand);
      }

      .services-grid-links {
        display: table;
        margin: 20px auto;
       

        editable-array-item {
          display: list-item;
          line-height: 1.2;
          margin: 10px auto;
        }

        a {
          color: var(--color-text);
          text-decoration: none;
        }
      }

      .services-grid-links editable-array-item:hover a,
      .services-grid-links editable-array-item:focus-within a,
      .services-grid-links li:hover a,
      .services-grid-links li:focus-within a {
        color: var(--color-brand-muted);
      }

      .services-grid-cta,
      #all {
        align-items: center;
        background-color: var(--color-brand);
        display: flex;
        flex: 0 1 400px;
        flex-direction: column;
        justify-content: center;
        max-width: 100%;
        min-height: 250px;
        text-align: center;
        transition: 0.4s all;

        &.is-wide {
          flex: 0 1 62%;
        }

        a {
          color: #fff;
          display: flex;
          flex-direction: column;
          gap: 0.625rem;
          justify-content: center;
          min-height: 100%;
          padding: 1.25rem;
          text-decoration: none;
          width: 100%;
        }
      }

      .services-grid-cta-heading,
      #all .h2 {
        color: #fff;
        font-family: var(--font-heading);
        font-size: clamp(2rem, 4.6vw, 3.3125rem);
        font-weight: 700;
        line-height: 1.05;
        padding: 10px;
      }

      .services-grid-cta-button,
      #all .btn {
        background-color: #fff;
        border: 0;
        color: var(--color-brand);
        display: inline-block;
        font-size: var(--font-size-body-sm);
        font-weight: 600;
        line-height: 1.2;
        padding: 0.65rem 1.1rem;
      }

      .services-grid-cta:hover .services-grid-cta-button,
      .services-grid-cta:focus-within .services-grid-cta-button,
      #all:hover .btn,
      #all:focus-within .btn {
        background-color: var(--color-brand-muted);
        color: #fff;
      }

      @media (max-width: 1200px) {
        .services-grid-items > editable-array-item,
        .services-grid-items > .services-grid-item {
          flex-basis: calc(50% - 10px);
        }

        .services-grid-items > editable-array-item.is-wide,
        .services-grid-items > .services-grid-item.is-wide,
        .services-grid-cta.is-wide,
        #all.is-wide {
          flex-basis: 100%;
        }
      }

      @media (max-width: 760px) {
        .services-grid-items > editable-array-item,
        .services-grid-items > .services-grid-item,
        .services-grid-items > editable-array-item.is-wide,
        .services-grid-items > .services-grid-item.is-wide,
        .services-grid-cta,
        #all,
        .services-grid-cta.is-wide,
        #all.is-wide {
          flex-basis: 100%;
        }
      }
    }
  }
</style>
