---
import RenderBlock from "@components/utils/renderBlock.astro";
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Button from "@core-elements/button/Button.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import Text from "@core-elements/text/Text.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Split from "@wrappers/split/Split.astro";

const {
  anchorName = "",
  heading = "",
  subtext = "",
  buttonSections = [],
  learnMoreButtonText = "",
  learnMoreSections = [],
  imageSource = "",
  imageAlt = "",
  reverse = false,
  colorScheme = "inherit",
  backgroundColor,
  backgroundGradient = "",
  backgroundImage,
  paddingVertical = "4xl",
  rounded = false,
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;

const headingPlainText = typeof heading === "string" ? heading.replace(/<[^>]*>/g, "").trim() : "";
const resolvedLearnMoreButtonText =
  learnMoreButtonText || (headingPlainText ? `Learn More About ${headingPlainText}` : "Learn More");
const hasLearnMoreContent = learnMoreSections?.length > 0;
const learnMoreId = `learn-more-${crypto.randomUUID()}`;
---

<CustomSection
  class:list={["cta-split learn-more-section", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  backgroundGradient={backgroundGradient}
  backgroundImage={backgroundImage}
  rounded={rounded}
  {...htmlAttributes}
>
  {anchorName && <a name={anchorName} class="anchor-name-offset" aria-hidden="true" />}
  <Split
    class="split"
    distributionMode="fixed-flexible"
    fixedWidth="400"
    verticalAlignment="center"
    reverse={reverse}
    minSplitWidth={640}
  >
    <Fragment slot="first">
      <Heading level="h2" size="xl" data-prop="heading" text={heading} />
      <Text data-prop="subtext" text={subtext} />
      <ButtonGroup class="buttons" buttonSections={buttonSections} direction="row" alignX="start" />
      {
        hasLearnMoreContent && (
          <Button
            class="learn-more-button"
            element="button"
            variant="primary"
            iconName="chevron-down"
            iconPosition="after"
            text={resolvedLearnMoreButtonText}
            data-prop="learnMoreButtonText"
            data-learn-more-trigger={learnMoreId}
            aria-controls={learnMoreId}
            aria-expanded="false"
          />
        )
      }
    </Fragment>
    <Fragment slot="second">
      <Image
        source={imageSource}
        rounded={true}
        alt={imageAlt}
        aspectRatio="landscape"
        editable={true}
        data-prop-src="imageSource"
        data-prop-alt="imageAlt"
        data-editable="image"
      />
    </Fragment>
  </Split>
  {
    hasLearnMoreContent && (
      <div id={learnMoreId} class="learn-more-content" hidden>
        <CustomSection
          class="learn-more-section"
          maxContentWidth="2xl"
          paddingHorizontal="none"
          paddingVertical="lg"
          colorScheme="inherit"
          backgroundColor="none"
        >
          <RenderBlock contentSections={learnMoreSections} propName="learnMoreSections" />
        </CustomSection>
      </div>
    )
  }
</CustomSection>

<script>
  const initCtaSplitLearnMore = () => {
    document.querySelectorAll("[data-learn-more-trigger]").forEach((trigger) => {
      if (trigger.getAttribute("data-learn-more-initialized") === "true") return;

      const targetId = trigger.getAttribute("data-learn-more-trigger");
      const target = targetId ? document.getElementById(targetId) : null;

      if (!target) return;

      const updateExpandedState = () => {
        const isExpanded = !target.hasAttribute("hidden");
        trigger.setAttribute("aria-expanded", isExpanded.toString());
        trigger.classList.toggle("is-open", isExpanded);
      };

      trigger.addEventListener("click", () => {
        target.toggleAttribute("hidden");
        updateExpandedState();
      });

      trigger.setAttribute("data-learn-more-initialized", "true");
      updateExpandedState();
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCtaSplitLearnMore);
  } else {
    initCtaSplitLearnMore();
  }
</script>

<style lang="pcss" is:global>
  @layer components {
    .cta-split.learn-more-section {
      .learn-more-button {
        margin-top: var(--spacing-sm);

        &.is-open .icon {
          transform: rotate(180deg);
        }

        .icon {
          transition: transform var(--animation-normal) ease-out;
        }
      }

      .learn-more-content {
        margin-top: var(--spacing-xl);
      }
    }
  }
</style>
