---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import mainNavData from "@data/mainNav.json";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

const {
  heading = "Sitemap",
  backgroundColor = "base",
  id = "",
  backgroundImage,
  backgroundGradient = "",
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);

type SitemapNode = {
  title: string;
  path?: string;
  children: SitemapNode[];
};

type NavItem = { name: string; path?: string; children?: NavItem[] };

const toTitleCase = (value = "") =>
  value
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .split(" ")
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");

const normalizeTitle = (value: unknown, fallback: string) => {
  if (typeof value !== "string") return fallback;
  const trimmed = value.trim();
  return trimmed.length > 0 ? trimmed : fallback;
};

const escapeHtml = (value: string) =>
  value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");

const ensureTrailingSlash = (path: string) => (path === "/" ? "/" : `${path.replace(/\/+$/, "")}/`);

// Build a map of normalized path → page title from all content collections
const routeTitleMap = new Map<string, string>();

const pages = await getCollection("pages");
const landingPages = await getCollection("landing-pages");
const blogPosts = await getCollection("blog");

pages.forEach((page: CollectionEntry<"pages">) => {
  const rawSlug = page.id.replace(/index$/, "");
  const fallbackTitle = rawSlug.length === 0 ? "Home" : toTitleCase(rawSlug.split("/").pop() || "");
  routeTitleMap.set(
    ensureTrailingSlash(rawSlug.length === 0 ? "/" : `/${rawSlug}`),
    normalizeTitle(page.data?.title, fallbackTitle)
  );
});

landingPages.forEach((page: CollectionEntry<"landing-pages">) => {
  const rawSlug = page.id.replace(/index$/, "");
  const fallbackTitle =
    rawSlug.length === 0 ? "Landing" : toTitleCase(rawSlug.split("/").pop() || "");
  routeTitleMap.set(
    ensureTrailingSlash(rawSlug.length === 0 ? "/landing" : `/landing/${rawSlug}`),
    normalizeTitle(page.data?.title, fallbackTitle)
  );
});

blogPosts.forEach((post: CollectionEntry<"blog">) => {
  const rawSlug = post.id?.replace(/\.mdx?$/, "") || post.slug;
  routeTitleMap.set(
    ensureTrailingSlash(`/blog/${rawSlug}`),
    normalizeTitle(post.data?.title, toTitleCase(rawSlug.split("/").pop() || "Blog Post"))
  );
});

// Walk navData recursively to produce ordered SitemapNodes
const navPathSet = new Set<string>();

const navItemToNode = (item: NavItem): SitemapNode => {
  const path = item.path ? ensureTrailingSlash(item.path) : undefined;
  if (path) navPathSet.add(path);
  return {
    title: item.name,
    path,
    children: (item.children || []).map(navItemToNode),
  };
};

const sitemapNodes: SitemapNode[] = (mainNavData.navData as NavItem[]).map(navItemToNode);

// Inject blog posts as children of the /blog/ nav node
const blogNavNode = sitemapNodes.find(
  (n) => n.path === "/blog/" || n.path === ensureTrailingSlash("/blog")
);
if (blogNavNode) {
  blogPosts
    .slice()
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .forEach((post: CollectionEntry<"blog">) => {
      const rawSlug = post.id?.replace(/\.mdx?$/, "") || post.slug;
      const path = ensureTrailingSlash(`/blog/${rawSlug}`);
      if (!navPathSet.has(path)) {
        const title = normalizeTitle(
          post.data?.title,
          toTitleCase(rawSlug.split("/").pop() || "Blog Post")
        );
        blogNavNode.children.push({ title, path, children: [] });
        navPathSet.add(path);
      }
    });
}

// Append any content pages not covered by the nav, sorted alphabetically
routeTitleMap.forEach((title, path) => {
  if (!navPathSet.has(path)) {
    sitemapNodes.push({ title, path, children: [] });
  }
});
sitemapNodes.sort((a, b) => {
  const aInNav = navPathSet.has(a.path ?? "");
  const bInNav = navPathSet.has(b.path ?? "");
  if (aInNav && !bInNav) return -1;
  if (!aInNav && bInNav) return 1;
  return 0;
});

const renderNodes = (nodes: SitemapNode[]): string => {
  if (nodes.length === 0) return "";
  const items = nodes
    .map((node) => {
      const label = escapeHtml(node.title);
      const link = node.path
        ? `<a href="${escapeHtml(node.path)}" title="${label}">${label}</a>`
        : `<span>${label}</span>`;
      return `<li>${link}${renderNodes(node.children)}</li>`;
    })
    .join("");
  return `<ul>${items}</ul>`;
};

const sitemapHtml = renderNodes(sitemapNodes);
---

<CustomSection
  class:list={["sitemap", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  backgroundImage={backgroundImage}
  style={backgroundGradient ? "--section-bg-gradient: " + backgroundGradient : undefined}
  {...htmlAttributes}
>
  <Heading level="h2" size="lg" alignX="center" text={heading} data-prop="heading" />

  <div class="sitemap-list" set:html={sitemapHtml} />

  <p class="sitemap-xml-link">
    <a href="/sitemap-index.xml">View XML Sitemap</a>
  </p>
</CustomSection>

<style>
  .sitemap {
    background: var(--section-bg-gradient, linear-gradient(transparent, transparent));

    .sitemap-list {
      margin: 2rem auto 0;
      max-width: 900px;

      :global(ul) {
        margin: 0;
        padding-left: 1.25rem;
      }

      :global(li) {
        margin: 0.25rem 0;
      }
    }

    .sitemap-xml-link {
      margin: 1.5rem auto 0;
      max-width: 900px;
      padding-left: 1.25rem;
    }
  }
</style>
