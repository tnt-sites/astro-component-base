---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import List from "@core-elements/list/List.astro";

const {
  heading = "",
  backgroundColor = "base",
  items = []
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["why", className]}
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <!-- <Image
    source="/src/assets/images/why-bg.jpg"
    alt=""
    class="background-image-why-bg"
    editable={false}
  /> -->

  <Heading
  level="h2"
  size="lg"
  alignX="center"
  data-prop="heading"
  >
    {heading}
  </Heading>

      <List items={items} direction="vertical" alignX="center" />

</CustomSection>

<style>
  .why .heading-text {
    text-transform: uppercase;
  }

    .list {
    margin-bottom: var(--spacing-lg);
  }
</style>