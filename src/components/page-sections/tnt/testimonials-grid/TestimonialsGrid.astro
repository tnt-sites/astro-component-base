---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";

const {
  heading = "",
  items = [],
  colorScheme = "inherit",
  backgroundColor = "surface",
  paddingVertical = "4xl",
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["tnt-testimonials-grid", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  {heading && (
    <Heading level="h2" size="lg" alignX="center" data-prop="heading">
      {heading}
    </Heading>
  )}
  <div class="tnt-testimonials-items" data-prop="items">
    {items.map((t: { quote: string; authorName: string; authorRole: string; image: string }) => (
      <div class="tnt-testimonial-card">
        <blockquote class="tnt-testimonial-quote">{t.quote}</blockquote>
        <footer class="tnt-testimonial-author">
          {t.image && (
            <img src={t.image} alt={t.authorName} class="tnt-testimonial-avatar" loading="lazy" />
          )}
          <div>
            <strong class="tnt-testimonial-name">{t.authorName}</strong>
            {t.authorRole && <span class="tnt-testimonial-role">{t.authorRole}</span>}
          </div>
        </footer>
      </div>
    ))}
  </div>
</CustomSection>

<style>
  .tnt-testimonials-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-xl);
  }
  .tnt-testimonial-card {
    padding: var(--spacing-xl);
    background: var(--color-base, #fff);
    border-radius: var(--radius-md, 8px);
    border-left: 4px solid var(--color-cta, #278575);
  }
  .tnt-testimonial-quote {
    font-style: italic;
    margin: 0 0 var(--spacing-md);
    color: var(--color-text);
    line-height: 1.6;
  }
  .tnt-testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  .tnt-testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }
  .tnt-testimonial-name { display: block; font-weight: 600; }
  .tnt-testimonial-role { display: block; font-size: var(--font-size-sm); color: var(--color-text-muted, #64748b); }
</style>
