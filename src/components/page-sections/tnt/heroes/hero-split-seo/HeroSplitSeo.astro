---
/**
 * TNT Hero Split (SEO variant)
 *
 * Same visual layout as page-sections/heroes/hero-split, but with
 * SEO-friendly heading hierarchy:
 *
 *   <h1>  Eyebrow text  (location + practice name — for local SEO ranking)
 *   <h2>  Visual headline
 *
 * Use this when the page has both:
 *   - An eyebrow text positioning the practice (e.g. "Wilmington Dentist")
 *   - A separate visual headline (e.g. "Smile Brighter, Live Happier")
 *
 * Otherwise use the base hero-split which puts the headline as H1.
 *
 * Used by: dental practices following local-SEO best practices.
 */
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import Text from "@core-elements/text/Text.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Split from "@wrappers/split/Split.astro";

const {
  eyebrow = "",
  heading = "",
  subtext = "",
  imageSource = "",
  imageAlt = "",
  imageAspectRatio = "none",
  buttonSections = [],
  reverse = false,
  colorScheme = "inherit",
  backgroundColor,
  paddingVertical = "4xl",
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  maxContentWidth="xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  class:list={["hero", "hero-seo", className]}
  {...htmlAttributes}
>
  <Split
    distributionMode="flexible-fixed"
    fixedWidth="400"
    verticalAlignment="center"
    reverse={reverse}
    minSplitWidth={710}
    gap="2xl"
    class="hero-split"
  >
    <Fragment slot="first">
      <h1 class="hero-eyebrow eyebrow" data-prop="eyebrow">
        {eyebrow}
      </h1>
      <Heading level="h2" size="2xl" data-prop="heading">
        {heading}
      </Heading>
      <Text class="subtext" data-prop="subtext" text={subtext} />
      <ButtonGroup class="buttons-container" buttonSections={buttonSections} />
    </Fragment>
    <Fragment slot="second">
      <Image
        source={imageSource}
        alt={imageAlt}
        rounded="true"
        editable={true}
        aspectRatio={imageAspectRatio}
        data-prop-src="imageSource"
        data-prop-alt="imageAlt"
        data-editable="image"
        priority={true}
      />
    </Fragment>
  </Split>
</CustomSection>
