---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@components/building-blocks/core-elements/image/Image.astro";
import Video from "@components/building-blocks/core-elements/video/Video.astro";
import Carousel from "@components/building-blocks/wrappers/carousel/Carousel.astro";
import CarouselSlide from "@components/building-blocks/wrappers/carousel/CarouselSlide.astro";
import Heading from "@core-elements/heading/Heading.astro";

const {
  heading = "",
  backgroundColor = "base",
  tourSlides = [],
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["office-tour", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <Heading level="h2" size="lg" alignX="center" data-prop="heading">
    {heading}
  </Heading>
  <Carousel
    label="Left carousel"
    slideWidthPercent={100}
    minSlideWidth={0}
    autoPlay={false}
    autoScroll={false}
    editable={editable}
  >
    {
      Array.isArray(tourSlides) &&
        tourSlides.length > 0 &&
        tourSlides.map((slide, index) => (
          <CarouselSlide aria-label={`Slide ${index + 1} of ${tourSlides.length}`}>
            {slide?._component === "building-blocks/core-elements/image" ? (
              <Image {...slide} data-index={index} />
            ) : slide?._component === "building-blocks/core-elements/video" ? (
              <Video {...slide} data-index={index} />
            ) : null}
          </CarouselSlide>
        ))
    }
  </Carousel>
</CustomSection>
