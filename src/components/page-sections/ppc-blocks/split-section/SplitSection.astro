---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";

const {
  desktopImage,
  mobileImage,
  figcaption = "",
  headingPrefix = "",
  headingMain = "",
  content = "",
  backgroundColor = "base",
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  id="dentist"
  class:list={["split-section", "container", "even", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <div class="flex-ed">
    <figure>
      <Image
        source={desktopImage?.source}
        class="desktop-image"
        alt={desktopImage?.alt}
        rounded={false}
        editable={false}
        aspectRatio="none"
        sizes="auto"
      />
      <Image
        source={mobileImage?.source}
        class="mobile-image"
        alt={mobileImage?.alt}
        rounded={false}
        editable={false}
        aspectRatio="none"
        sizes="auto"
      />
      {figcaption && <figcaption>{figcaption}</figcaption>}
    </figure>
    <article>
      <Heading level="h2" size="lg" editable={false}>
        {headingPrefix && <small>{headingPrefix}</small>}
        {headingMain}
      </Heading>
      <div class="content" set:html={content} />
    </article>
  </div>
</CustomSection>

<style>
  .split-section {
    display: flex;
    flex-wrap: wrap;
    margin: 0 auto;
    max-width: 1220px;
    padding: 50px 10px 60px;
    position: relative;
    width: 100%;
    z-index: 2;
  }

  .outer-content {
    width: 100%;
  }

  .split-section .flex-ed {
    align-items: flex-start;
    display: flex;
    flex-wrap: nowrap;
    gap: 2rem;
    justify-content: center;
    width: 100%;
  }

  .split-section figure {
    flex: 0 1 525px;
    position: relative;
  }

  .split-section figure img {
    position: relative;
    width: 100%;
  }

  .split-section figcaption {
    background: transparent;
    bottom: auto;
    color: #000;
    font-size: 1.125rem;
    font-weight: 400;
    left: auto;
    letter-spacing: 0.2em;
    padding: 10px 0;
    position: relative;
    text-align: left;
    text-transform: uppercase;
    width: 100%;
  }

  .split-section article {
    flex: 0 1 540px;
    padding: 5px;
    text-align: left;
  }

  .split-section h2 {
    color: #000;
    font-size: 2.8125rem;
    font-weight: 500;
    letter-spacing: -1.05px;
    line-height: 1;
    margin-top: 0;
    text-align: left;
  }

  .split-section h2 small {
    color: #6a6869;
    display: block;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    line-height: 1.5;
    margin-bottom: 10px;
    padding-left: 50px;
    position: relative;
    text-transform: uppercase;
  }

  .split-section h2 small:after {
    background: #6a6869;
    content: "";
    height: 1px;
    left: 0;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 42px;
  }

  .split-section .content p {
    color: #000;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .desktop-image {
    display: block;
  }

  .mobile-image {
    display: none;
  }

  @media (max-width: 1024px) {
    .split-section .flex-ed {
      align-items: center;
      flex-direction: column;
    }

    .split-section figure {
      margin-right: 0;
      order: -1;
    }

    .split-section article {
      flex: 0 1 auto;
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .split-section {
      padding: 30px 10px;
    }

    .split-section .flex-ed {
      flex-direction: column;
      gap: 1rem;
    }

    .desktop-image {
      display: none;
    }

    .mobile-image {
      display: block;
    }

    .split-section h2 {
      font-size: 2rem;
    }

    .split-section article {
      padding: 20px 10px;
      text-align: center;
    }

    .split-section h2 small:after {
      display: none;
    }

    .split-section h2 small {
      padding-left: 0;
    }
  }

  @media (min-width: 769px) {
    .desktop-image {
      display: block;
    }

    .mobile-image {
      display: none;
    }
  }
</style>
