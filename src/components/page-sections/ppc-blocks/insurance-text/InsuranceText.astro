---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";

const {
  heading = "",
  text = "",
  backgroundColor = "base",
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["insurance-text", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <Heading
    class:list={["insurance-text--heading", className]}
    level="h2"
    size="xl"
    alignX="left"
    data-prop="heading"
  >
    {
      heading.split("||").map((line, i) => (
        <>
          {line}
          {i === 0 ? <br class="mobile-break" /> : null}
        </>
      ))
    }
  </Heading>
  <Text>
    {text}
  </Text>
</CustomSection>

<style>
  .insurance-text--heading {
    align-items: center;
    display: flex;
    font-size: 50px;
    justify-content: center;
    margin: 10px auto;
    position: relative;
    text-align: left;
    z-index: 2;
  }
  .insurance-text--heading:after {
    background-color: #6a6869;
    content: "";
    flex: 1;
    height: 2px;
    margin-left: 30px;
  }

  .mobile-break {
    display: none;
  }

  @media (max-width: 1024px) {
    .insurance-text--heading {
      display: block;
      text-align: center;
    }
    .insurance-text--heading:after {
      display: block;
      margin: 10px auto;
      position: static;
      width: 180px;
    }
  }

  @media (max-width: 768px) {
    .mobile-break {
      display: inline;
    }
  }
</style>
