---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Text from "@core-elements/text/Text.astro";

const {
  heading = "",
  backgroundColor = "base",
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["blurb", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <article class="looking">
    <Text size="lg" alignX="center">
      {heading}
    </Text>
  </article>
</CustomSection>

<style>
  .blurb {
  }

  .looking {
    background: #fff;
    border-radius: 5px;
    box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.17);
    margin: 100px auto;
    max-width: 1140px;
    padding: 20px 30px;
  }

  .looking p {
    font-size: 20px;
    font-weight: 500;
    line-height: 1.5;
    margin: auto;
    padding: 15px 10px;
    text-align: center;
  }

  .looking p span {
    font-size: 30px;
    font-weight: 400;
  }
</style>
