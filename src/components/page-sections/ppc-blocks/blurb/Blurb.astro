---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Text from "@core-elements/text/Text.astro";

const {
  text = "",
  backgroundColor = "none",
  class: className,
  blurbBackgroundColor = "none",
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["blurb", className]}
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <article
    class:list={["looking", blurbBackgroundColor !== "none" && `bg-${blurbBackgroundColor}`]}
  >
    <Text size="lg" alignX="center">
      {text}
    </Text>
  </article>
</CustomSection>

<style>
  .blurb {
  }

  .looking {
    border-radius: 5px;
    box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.17);
    margin: 100px auto;
    max-width: 1140px;
    padding: 20px 30px;
  }

  .looking .text {
    font-size: 20px;
    font-weight: 500;
    line-height: 1.5;
    margin: auto;
    padding: 15px 10px;
    text-align: center;
  }

  .looking .text strong,
  .looking .text b {
    font-size: 30px;
    font-weight: 400;
  }
</style>
