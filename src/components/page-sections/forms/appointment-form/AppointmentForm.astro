---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";
import Form from "@forms/form/Form.astro";

const {
  heading = "Request an Appointment",
  subtext = "",
  formAction = "./",
  formBlocks = [],
  backgroundColor = "base",
  id = "",
  backgroundImage,
  backgroundGradient = "",
  class: className,
  editable = true,
  ...rest
} = Astro.props;

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["appointment-form", className]}
  maxContentWidth="xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  backgroundImage={backgroundImage}
  style={backgroundGradient ? "--section-bg-gradient: " + backgroundGradient : undefined}
  {...htmlAttributes}
>
  <Heading level="h2" size="xl" alignX="center" data-prop="heading" text={heading} />
  {
    subtext && (
      <Text alignX="center" data-prop="subtext">
        {subtext}
      </Text>
    )
  }
  <Form class="appt-form" action={formAction} formBlocks={formBlocks?.length > 0 ? formBlocks : []}>
    <slot />
  </Form>
</CustomSection>

<style lang="pcss" is:global>
  @layer page-sections {
    .appointment-form {
      background: var(--section-bg-gradient, linear-gradient(transparent, transparent));

      .appt-form.form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 var(--spacing-xl);

        > editable-array {
          display: contents;
        }

        editable-array-item {
          display: block;
          min-width: 0;
        }

        editable-array-item:has(.hidden) {
          display: contents;
        }

        editable-array-item:has(.submit) {
          grid-column: 1 / -1;
          display: flex;
          justify-content: center;
        }

        .submit {
          display: block;
          margin-inline: auto;
        }

        @media (max-width: 750px) {
          grid-template-columns: 1fr;
        }
      }
    }
  }
</style>
