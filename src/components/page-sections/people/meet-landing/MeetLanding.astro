---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import MeetLandingPerson from "./MeetLandingPerson.astro";

type MeetLandingPersonItem = {
  _component?: string;
  name?: string;
  href?: string;
  imageSource?: string;
  imageAlt?: string;
};

const {
  variant = "button",
  doctors = [],
  providers = [],
  backgroundColor = "base",
  id = "",
  backgroundImage,
  backgroundGradient = "",
  class: className,
  editable = true,
  _component,
  ...rest
} = Astro.props;

const cleanText = (value: unknown, fallback = "") =>
  typeof value === "string" && value.trim().length > 0 ? value.trim() : fallback;

const normalizedVariant = variant === "name" ? "name" : "button";
const variantClass = normalizedVariant === "name" ? "landing--names" : "landing--buttons";

const doctorItems =
  Array.isArray(doctors) && doctors.length > 0
    ? doctors
    : Array.isArray(providers)
      ? providers
      : [];

const normalizedDoctors = Array.isArray(doctorItems)
  ? doctorItems
      .filter((doctor): doctor is MeetLandingPersonItem => !!doctor && typeof doctor === "object")
      .map((doctor) => ({
        name: cleanText(doctor.name, "Provider Name"),
        href: cleanText(doctor.href, "#"),
        imageSource: cleanText(doctor.imageSource),
        imageAlt: cleanText(doctor.imageAlt),
      }))
  : [];

const hasDoctors = normalizedDoctors.length > 0;

const doctorsArrayDataAttributes = editable
  ? {
      "data-editable": "array",
      "data-component-key": "_component",
      "data-id-key": "_component",
      "data-prop": "doctors",
    }
  : {};

if (!_component && !hasDoctors) {
  return;
}

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["meet-landing", className]}
  id={id || undefined}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  backgroundImage={backgroundImage}
  style={backgroundGradient ? "--section-bg-gradient: " + backgroundGradient : undefined}
  {...htmlAttributes}
>


  {
    hasDoctors && (
      <div class:list={["landing", variantClass]} {...doctorsArrayDataAttributes}>
        {normalizedDoctors.map((doctor) => (
          <editable-array-item data-component="page-sections/people/meet-landing/meet-landing-person">
            <MeetLandingPerson {...doctor} variant={normalizedVariant} editable={editable} />
          </editable-array-item>
        ))}
      </div>
    )
  }
</CustomSection>

<style lang="pcss" is:global>
  .meet-landing {
    background:
      var(
        --section-bg-gradient,
        linear-gradient(transparent, transparent)
      );

    .landing {
      align-items: flex-start;
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      justify-content: center;
      margin-top: 1.5rem;
    }

    .landing > editable-array-item,
    .landing > a {
      flex: 0 1 auto;
      text-align: center;
    }

    .landing a {
      display: block;
      text-align: center;
      text-decoration: none;
    }

    .landing .btn {
      margin: 20px auto 0;
    }

    .landing .name {
      color: #fff;
      display: block;
      font-size: 18px;
      margin: 10px auto 0;
    }

    .landing a:hover .name,
    .landing a:focus-visible .name {
      color: var(--color-brand);
    }

    @media (max-width: 760px) {
      .landing {
        gap: 12px;
      }

      .landing > editable-array-item,
      .landing > a {
        flex-basis: calc(50% - 6px);
      }
    }

    @media (max-width: 520px) {
      .landing > editable-array-item,
      .landing > a {
        flex-basis: 100%;
      }
    }
  }
</style>