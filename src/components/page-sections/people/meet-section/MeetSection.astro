---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@components/building-blocks/core-elements/image/Image.astro";
import Text from "@components/building-blocks/core-elements/text/Text.astro";
import Card from "@components/building-blocks/wrappers/card/Card.astro";
import Heading from "@core-elements/heading/Heading.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
const {
  heading = "",
  backgroundImage,
  class: className,
  imageSource = "",
  imageAlt = "",
  doctors = [],

  editable = true,
  ...rest
} = Astro.props;

const { source = "", alt = "" } = backgroundImage || {};

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["meet-section", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  {...htmlAttributes}
>
  <Image
    class:list={["background-image"]}
    source={source}
    alt={alt}
    editable={editable}
    data-prop-src="backgroundImage.source"
    data-prop-alt="backgroundImage.alt"
    background={true}
  />
  <Heading
    level="h2"
    size="lg"
    alignX="center"
    data-prop="heading"
    style="text-transform: uppercase;"
  >
    {heading}
  </Heading>

  <Image
    source={imageSource}
    alt={imageAlt}
    editable={editable}
    data-prop-src="imageSource"
    data-prop-alt="imageAlt"
    width={1135}
    height={652}
  />
  <div class="meet-content">
    {
      doctors.map((doctor: any, index: number) => (
        <Card key={index} {...doctor}>
          <Heading level="h3" size="md" alignX="center" data-prop={`doctors.${index}.name`}>
            {doctor.name}
          </Heading>
          <Text style="text-align: center" data-prop={`doctors.${index}.text`}>
            {doctor.text}
          </Text>
          <ButtonGroup class="buttons" buttonSections={doctor.buttonSections} alignX="center" />
        </Card>
      ))
    }
  </div>
</CustomSection>

<style lang="pcss" is:global>
  @layer page-sections {
    .meet-section {
      position: relative;
    background-color: #EBECF0;
    width: 100%;
    max-width: 1300px;
    margin: 100px auto;;
    }

    .bg-base{background-color: transparent;}

    .background-image{
      position: absolute;
    opacity: 0.8;
    left: auto;
    right: 0;
    top: 0;
    z-index: -1;
    max-width: 277px;
    height: 534px;
    }

    .meet-content{
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: space-around;

    }

    .card{
          max-width: 420px;
    margin-top: 50px;display: block;; flex: 0 1 420px;

    h3{font-size: 4rem; font-weight: normal;}
    .text{font-size: 1.8rem; font-weight: 500;     max-width: 370px; margin: 0 auto;}
    }
  }
</style>
