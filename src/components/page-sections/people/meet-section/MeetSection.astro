---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Image from "@components/building-blocks/core-elements/image/Image.astro";
import Text from "@components/building-blocks/core-elements/text/Text.astro";
import Card from "@components/building-blocks/wrappers/card/Card.astro";
import Split from "@components/building-blocks/wrappers/split/Split.astro";
import Heading from "@core-elements/heading/Heading.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  heading = "",
  backgroundColor = "base",
  backgroundImage,
  class: className,
  imageSource = "",
  imageAlt = "",
  firstHeadingText = "",
  firstText = "",
  secondHeadingText = "",
  secondText = "",
  buttonSections = [],

  editable = true,
  ...rest
} = Astro.props;

const {
  source = "",
  alt = "",
  positionVertical = "top",
  positionHorizontal = "center",
} = backgroundImage || {};

const htmlAttributes = Object.fromEntries(
  Object.entries(rest).filter(([key]) => key !== "_component")
);
---

<CustomSection
  class:list={["meet-section", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="4xl"
  colorScheme="default"
  backgroundColor={backgroundColor}
  {...htmlAttributes}
>
  <Image
    class:list={["background-image"]}
    source={source}
    alt={alt}
    editable={editable}
    data-prop-src="backgroundImage.source"
    data-prop-alt="backgroundImage.alt"
    positionVertical={positionVertical}
    positionHorizontal={positionHorizontal}
    background={true}
  />
  <Heading
    level="h2"
    size="lg"
    alignX="center"
    data-prop="heading"
    style="text-transform: uppercase;"
  >
    {heading}
  </Heading>

  <Image
    source={imageSource}
    alt={imageAlt}
    editable={editable}
    data-prop-src="imageSource"
    data-prop-alt="imageAlt"
    width={1135}
    height={652}
  />

  <Split>
    <Fragment slot="first">
      <Card
        class="meet-card"
        border={true}
        rounded={true}
        paddingHorizontal="lg"
        paddingVertical="lg"
      >
        <Heading level="h3" size="md" data-prop="firstHeadingText">
          {firstHeadingText}
        </Heading>
        <Text text={firstText} data-prop="firstText" />
        <ButtonGroup class="meet-card-buttons" buttonSections={buttonSections} alignX="start" />
      </Card>
    </Fragment>

    <Fragment slot="second">
      <Card
        class="meet-card"
        border={true}
        rounded={true}
        paddingHorizontal="lg"
        paddingVertical="lg"
      >
        <Heading level="h3" size="md" data-prop="secondHeadingText">
          {secondHeadingText}
        </Heading>
        <Text text={secondText} data-prop="secondText" />
        <ButtonGroup class="meet-card-buttons" buttonSections={buttonSections} alignX="start" />
      </Card>
    </Fragment>
  </Split>
</CustomSection>

<style lang="pcss" is:global>
  @layer page-sections {
    .meet-section {
      .meet-card {
        height: 100%;
      }
    }
  }
</style>
